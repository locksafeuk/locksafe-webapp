  defect     String // description of issue found
  difficulty String // easy, medium, hard, specialist

  // Parts breakdown
  parts QuotePart[]

  // Labour
  labourCost Float
  labourTime Int // estimated minutes

  // Totals
  partsTotal Float
  subtotal   Float
  vat        Float
  total      Float

  // Status
  accepted   Boolean   @default(false)
  acceptedAt DateTime?
  declinedAt DateTime?

  createdAt DateTime @default(now())
