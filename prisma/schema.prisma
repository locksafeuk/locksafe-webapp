// ============================================
// AI AGENT OPERATING SYSTEM MODELS
// ============================================

// Agent definition - autonomous AI workers
model Agent {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String @unique // "ceo", "cto", "cmo", "coo"
  displayName String // "CEO Agent", "COO Agent"
  role        String // Role description

  // Hierarchy
  parentAgentId String? @db.ObjectId

  status     String @default("active") // active, paused, terminated
  skillsPath String // Path to SKILL.md file

  // Budget Control
  monthlyBudgetUsd Float    @default(50) // Monthly token budget ($)
  budgetUsedUsd    Float    @default(0) // Current month usage
  budgetResetAt    DateTime @default(now()) // When budget resets

  // Daily budget cap (optional, opt-in). Null = no daily cap (no behaviour change).
  dailyBudgetUsd Float? // Per-day spend ceiling ($); when set, heartbeats stop once reached
  dailyUsedUsd   Float     @default(0) // Spend in the current UTC day
  budgetDayStart DateTime? // Start of the current daily window (UTC)

  // Heartbeat Configuration
  heartbeatEnabled  Boolean   @default(true)
  heartbeatCronExpr String    @default("*/30 * * * *") // Cron expression
  lastHeartbeat     DateTime?
  nextHeartbeat     DateTime?

  // Permissions
  permissions     String[] @default([]) // Tool access list
  governanceLevel String   @default("autonomous") // autonomous, supervised, approval_required

  // Stats
  totalTasksCompleted Int   @default(0)
  totalExecutions     Int   @default(0)
  successRate         Float @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks      AgentTask[]
  executions AgentExecution[]
  memories   AgentMemory[]
}

// Task assigned to an agent
model AgentTask {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  agentId String @db.ObjectId
  agent   Agent  @relation(fields: [agentId], references: [id])

  parentTaskId String? @db.ObjectId // Parent task (delegation)

  title       String
  description String
  priority    Int    @default(5) // 1-10, 10 = highest
  status      String @default("pending") // pending, in_progress, completed, failed, blocked

  // Goal Alignment
  companyGoalId  String? @db.ObjectId
  projectContext String? // Context about what this achieves

  // Delegation
  delegatedFrom String? // Agent that delegated this
  delegatedTo   String? // Subagent to execute

  // Execution
  assignedAt  DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  deadline    DateTime?

  // Results
  result        String? // JSON result
  resultSummary String? // Human-readable summary
  error         String?

  // Cost tracking
  tokensUsed Int   @default(0)
  costUsd    Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Agent execution log (immutable audit trail)
model AgentExecution {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  agentId String @db.ObjectId
  agent   Agent  @relation(fields: [agentId], references: [id])

  taskId  String? @db.ObjectId
  traceId String // Group related executions

  // Execution details
  actionType String // tool_call, decision, delegation, heartbeat
  actionName String // Tool name or action description
  input      String // JSON input
  output     String? // JSON output
  status     String  @default("success") // success, failed, blocked, pending_approval

  // Cost tracking
  tokensUsed Int     @default(0)
  costUsd    Float   @default(0)
  model      String? // AI model used (gpt-4, etc)

  // Timing
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?

  // Approval (if needed)
  requiresApproval Boolean   @default(false)
  approvedBy       String? // Admin who approved
  approvedAt       DateTime?

  createdAt DateTime @default(now())

  @@index([startedAt(sort: Desc)])
  @@index([agentId, startedAt(sort: Desc)])
}

// Agent memory (short + long term)
model AgentMemory {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  agentId String @db.ObjectId
  agent   Agent  @relation(fields: [agentId], references: [id])

  type     String @default("short") // short, long, system
  category String // decisions, campaigns, patterns, bugs, etc

  content  String // The memory content
  metadata String? // JSON metadata

  // Relevance
  importance     Float    @default(0.5) // 0-1 importance score
  lastAccessedAt DateTime @default(now())
  accessCount    Int      @default(1)

  // Expiry
  expiresAt DateTime? // Null = permanent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Company goals (for goal alignment)
model CompanyGoal {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  title       String
  description String
  type        String @default("strategic") // strategic, quarterly, project

  status   String @default("active") // active, completed, paused
  priority Int    @default(5) // 1-10

  // Metrics
  targetMetric String? // What we're measuring
  targetValue  Float? // Target value
  currentValue Float? // Current progress
  progress     Float   @default(0) // 0-100%

  // Ownership
  ownerAgentId String? @db.ObjectId // Primary agent responsible

  deadline    DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// VOICE AI RECEPTIONIST SYSTEM (Retell AI)
// ==========================================

// Voice call records from Retell AI
model VoiceCall {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Retell AI identifiers
  retellCallId String  @unique // Retell's call_id
  agentId      String? // Retell agent ID used
  configVersionId String? @db.ObjectId

  // Caller info
  callerPhone    String? // Caller's phone number
  callerName     String? // Extracted from conversation
  callerPostcode String? // Extracted postcode

  // Call metadata
  callType        String    @default("inbound") // inbound, outbound, web
  callStatus      String    @default("in_progress") // in_progress, completed, failed, transferred
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationSeconds Int?

  // Classification
  callCategory String? // emergency, appointment, inquiry, complaint, spam
  urgencyLevel String? // critical, high, medium, low
  problemType  String? // lockout, broken_lock, security_upgrade, rekeying, consultation
  propertyType String? // residential, commercial, automotive

  // Outcome
  outcome        String? // job_created, appointment_booked, info_provided, escalated, abandoned
  outcomeDetails Json? // Details about the outcome

  // Linked entities
  jobId       String?   @db.ObjectId // Created job (if any)
  customerId  String?   @db.ObjectId // Linked customer (if identified)
  locksmithId String?   @db.ObjectId // Dispatched locksmith (if any)
  bookingDate DateTime? // For appointment bookings

  // Sentiment & quality
  sentimentScore       Float? // -1 to 1 (negative to positive)
  sentimentLabel       String? // positive, neutral, negative
  customerSatisfaction Int? // 1-5 post-call survey

  // Transcript
  transcript Json? // Full transcript array [{role, content, timestamp}]
  summary    String? // AI-generated call summary

  // Recording
  recordingUrl      String?
  recordingDuration Int?

  // Call analysis from Retell
  callAnalysis Json? // Full analysis object from Retell

  // Revenue attribution
  estimatedRevenue Float? // Estimated revenue from this call
  actualRevenue    Float? // Actual revenue (after job completion)

  // Deduplication
  dedupeKey String? @unique // For webhook deduplication

  // Human escalation
  wasEscalated     Boolean @default(false)
  escalationReason String?
  escalatedTo      String? // Phone number or name of human agent

  // Flags
  flaggedForReview Boolean @default(false)
  reviewNotes      String?
  isTestCall       Boolean @default(false)

  reviews VoiceCallReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([callerPhone])
  @@index([callCategory])
  @@index([callStatus])
  @@index([startedAt])
  @@index([outcome])
}

// Voice agent configuration and prompts
model VoiceAgentConfig {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name     String  @unique // Config name/version
  isActive Boolean @default(false)

  // Retell AI config
