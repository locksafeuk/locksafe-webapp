  maxCallDuration Int     @default(600) // Max seconds (10 min default)
  silenceTimeout  Int     @default(10) // Seconds of silence before prompting
  enableRecording Boolean @default(true)

  // Business hours
  businessHoursStart String  @default("00:00") // 24/7 by default
