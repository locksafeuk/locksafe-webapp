  pillar   ContentPillar? @relation(fields: [pillarId], references: [id])
  hashtags String[]

  // Platform targeting
  platforms SocialPlatform[] @default([FACEBOOK, INSTAGRAM])

  // AI generation metadata
  aiGenerated    Boolean @default(false)
  aiPrompt       String? // Original prompt used
  aiFramework    String? // "justin-welsh", "russell-brunson", etc.
  emotionalAngle String? // "urgency", "trust", "fear", etc.

  // Scheduling & Status
  status       PostStatus @default(DRAFT)
  scheduledFor DateTime?
  publishedAt  DateTime?

  // Publishing results
  facebookPostId   String? // Post ID after publishing to Facebook
  instagramPostId  String? // Post ID after publishing to Instagram
  twitterPostId    String? // Tweet ID after publishing to Twitter/X
  twitterThreadIds String[] // IDs of all tweets in a thread
  linkedinPostId   String? // LinkedIn UGC post URN after publishing
  tiktokPostId     String? // TikTok video ID (future auto-publishing)
  publishError     String? // Error message if publish failed

  // Platform-specific content variants (rewritten for each platform's native style)
  facebookContent    String? // Facebook-optimised copy (200-300 chars + 5-8 hashtags)
  instagramContent   String? // Instagram caption (100-150 chars + 20-30 hashtags)
  twitterContent     String? // Single tweet (max 270 chars + 2-3 hashtags)
