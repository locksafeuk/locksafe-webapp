// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────────────────
// Control plane (agent autonomy redesign — see AGENT_AUTONOMY_REDESIGN_*.md)
// ────────────────────────────────────────────────────────────────────────────

// Every action an agent proposes, recorded BEFORE validation for a full audit
// trail (what the agent wanted to do, independent of whether it ran).
model AgentProposal {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  agent        String
  actionType   String
  args         String // JSON
  rationale    String   @default("")
  evidenceRefs String[] @default([])

  // Pipeline decision + validator outcome
  decision         String // execute | approve | reject (initial classification)
  finalDecision    String? // executed | executed-idempotent | queued-for-approval | rejected | execute-failed
  validationCode   String? // machine-readable validator code (e.g. "no-demand")
  validationReason String?
  idempotencyKey   String?

  // True = dry-run (shadow mode): decided + recorded but NOT acted on.
  shadow Boolean @default(false)

  // Human "this alert was noise" signal (for alert.raise proposals) — feeds the
  // alert_noise_rate self-improvement metric.
  dismissedAsNoise Boolean   @default(false)
  dismissedAt      DateTime?
  dismissedBy      String?

  proposedAt DateTime  @default(now())
  resolvedAt DateTime?

  @@index([agent, proposedAt(sort: Desc)])
  @@index([actionType, decision, proposedAt(sort: Desc)])
  @@index([shadow, proposedAt(sort: Desc)])
}

// Distributed lock so the PM2 runner and the Vercel cron can never run the same
// agent concurrently (eliminates double-fire / double-spend).
model AgentHeartbeatLock {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  agent      String   @unique
  nodeId     String
  acquiredAt DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}

// Idempotency ledger: a repeated action (same key) returns the prior result
// instead of executing again.
model ActionIdempotency {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  key        String   @unique
  actionType String
  result     String // JSON ExecutionResult
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}

// Self-improvement: a parameter the system may auto-tune within hard bounds.
model TunableParameter {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  key        String   @unique
  value      Float
  min        Float
  max        Float
  step       Float
  betterWhen String // "higher" | "lower"
  metric     String // outcome metric this optimises
  /// The last applied change to value (for the hill-climb direction).
  lastDelta  Float    @default(0)
  /// The metric value observed at the previous run (the hill-climb baseline).
  lastMetric Float?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

// Self-improvement: an auto-tuning decision (changelog + rollback audit).
model ParameterChange {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  key          String
  fromValue    Float
  toValue      Float
  action       String // explore | continue | rollback | hold
  reason       String
  metricBefore Float?
  metricAfter  Float?
  /// True = suggestion only (shadow); false = actually applied.
  shadow       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([key, createdAt(sort: Desc)])
}

// Stripe onboarding reminder log for auditing admin sends
model StripeReminderLog {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  locksmithId  String   @db.ObjectId
  locksmith    Locksmith @relation(fields: [locksmithId], references: [id])
  adminEmail   String
  sentAt       DateTime @default(now())
}

model BaseLocationReminderLog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  locksmithId String    @db.ObjectId
  locksmith   Locksmith @relation(fields: [locksmithId], references: [id])
  adminEmail  String
  sentAt      DateTime  @default(now())
}

model AppInstallReminderLog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  locksmithId String    @db.ObjectId
  locksmith   Locksmith @relation(fields: [locksmithId], references: [id])
  adminEmail  String
  resendEmailId String?
  status      String    @default("sent") // sent | delivered | opened | clicked | bounced | complained
  deliveredAt DateTime?
  openedAt    DateTime?
  openCount   Int       @default(0)
  clickedAt   DateTime?
  clickCount  Int       @default(0)
  clickedLinks String[] @default([])
  bouncedAt   DateTime?
  bounceReason String?
  complainedAt DateTime?
  sentAt      DateTime  @default(now())

  @@index([locksmithId, sentAt])
  @@index([resendEmailId])
}

// Audit log for admin WhatsApp click-to-chat button clicks.
// One row per click; non-blocking — admin still gets to WhatsApp if the
// log call fails. Used for "who contacted whom about what" reporting.
model WhatsAppClickLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  actorId     String   // admin user id from JWT payload (sub)
  actorEmail  String
  targetType  String   // "locksmith" | "lead" | "customer"
  targetId    String
  jobId       String?
  phone       String   // recipient phone, raw as displayed
  clickedAt   DateTime @default(now())

  @@index([targetId, clickedAt])
  @@index([actorId, clickedAt])
}

// Persistent WhatsApp inbox for admin-side in-app messaging.
model WhatsAppConversation {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  waId              String?  @unique // WhatsApp wa_id when known (digits-only)
  phone             String   // Normalized destination/source phone
  contactName       String?
  assignedAdminId   String?
  assignedAdminEmail String?
  assignedAdminName String?
  assignedAt        DateTime?
  isUrgent          Boolean  @default(false)
  lastMessageAt     DateTime @default(now())
  lastMessagePreview String?
  unreadCount       Int      @default(0)
  archived          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  messages WhatsAppConversationMessage[]

  @@index([phone])
  @@index([lastMessageAt])
  @@index([assignedAdminId, lastMessageAt])
  @@index([isUrgent, lastMessageAt])
}

model WhatsAppConversationMessage {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId  String   @db.ObjectId
  conversation    WhatsAppConversation @relation(fields: [conversationId], references: [id])

  direction       String   // inbound | outbound
  messageType     String   // text | interactive | template | status
  content         String?
  providerMessageId String?
  status          String?  // sent | delivered | read | failed
  rawPayload      Json?
  createdAt       DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([providerMessageId])
}

// Admin user model
model Admin {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin") // admin, super_admin
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Prospective locksmith leads (found via Google Places scraper)
model LocksmithLead {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  googlePlaceId String    @unique
  name          String
  city          String
  address       String
  phone         String?
  website       String?
  email         String? // Manually added after research
  rating        Float     @default(0)
  reviewCount   Int       @default(0)
  // Outreach tracking
  status        String    @default("new") // new | contacted | replied | onboarded | not_interested
  notes         String?
  contactedAt   DateTime?
  contactedBy   String? // Admin name/id who contacted
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Lead batch intake tracking (for scraper → agent monitoring)
model LeadBatch {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  batchId       String    @unique // External batch ID from scraper
  source        String    @default("scraper") // scraper, manual, import, etc.
  leadCount     Int // Number of leads in this batch
  leadIds       String[]  @default([]) // Optional: specific lead IDs in this batch
  status        String    @default("received") // received, processing, completed, failed
  processedAt   DateTime  @default(now())
  completedAt   DateTime?
  errorMessage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, processedAt])
}

// Scraper run progress — persisted in DB so Vercel cron invocations can
// resume across the 300-second function limit without relying on /tmp.
// One active record per scrape cycle; completed cycles are kept for audit.
model ScraperProgress {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  runId           String   @unique @default(cuid())
  // Cities finished in this cycle (JSON-safe city names from UK_CITIES list)
  completedCities String[] @default([])
  // Running totals for this cycle
  totalLeadsFound Int      @default(0)
  totalLeadsSaved Int      @default(0)
  // Metadata
  isComplete      Boolean  @default(false)
  lastRunAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isComplete, createdAt])
}

// Customer/Client model
model Customer {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String? @unique
  phone        String
  passwordHash String? // Optional - for account-based customers

  // Source tracking
  createdVia String @default("web") // web, phone, app

  // Stripe Customer (for saving payment methods)
  stripeCustomerId      String? // Stripe customer ID
  stripePaymentMethodId String? // Default saved payment method ID

  // Email verification
  emailVerified           Boolean   @default(false)
  verificationToken       String?
  verificationTokenExpiry DateTime?

  // Password reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Onboarding & Terms
  termsAcceptedAt     DateTime? // When customer accepted T&C
  onboardingCompleted Boolean   @default(false)
  passwordSet         Boolean   @default(false) // Whether customer has set a password
  locationConfirmed   Boolean   @default(false) // Whether customer confirmed their location

  // WhatsApp support integration
  whatsappChatId   String? // WhatsApp chat ID for support
  whatsappVerified Boolean @default(false)

  // Referral system
  referralCode    String? // Their own shareable code (e.g. SARAH-X4K2) - sparse unique index managed in Atlas
  referralCredits Float   @default(0) // Available £ credits from referrals
  referredByCode  String? // Code they signed up with

  // LockSafe Cover subscription
  subscription Subscription?

  // B2B / Landlord
  orgMemberships OrgMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]
  reviews   Review[]
}

// ==========================================
// LOCKSMITH TEAM / COMPANY ACCOUNTS
// ==========================================

model LocksmithCompany {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name               String // Trading name, e.g. "London Fast Locks Ltd"
  registrationNumber String? // Companies House number (optional)
  contactEmail       String  @unique
  contactPhone       String

  // Owner / manager locksmith
  ownerId String?    @db.ObjectId
  owner   Locksmith? @relation("CompanyOwner", fields: [ownerId], references: [id])

  // Shared Stripe Connect (all payouts go here)
  stripeConnectId        String?
  stripeConnectOnboarded Boolean @default(false)
  stripeConnectVerified  Boolean @default(false)

  // Billing
  billingEmail String?
  vatNumber    String?

  // Team members (via join table — allows per-member commission rates)
  memberships LocksmithCompanyMember[]

  isActive Boolean @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-member commission agreement within a team
model LocksmithCompanyMember {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  companyId String           @db.ObjectId
  company   LocksmithCompany @relation(fields: [companyId], references: [id])

  locksmithId String    @db.ObjectId
  locksmith   Locksmith @relation("TeamMemberships", fields: [locksmithId], references: [id])

  // Earnings split: after the platform takes its fee, what % goes to the locksmith?
  // Manager retains (100 - locksmithSplit)%
  locksmithSplit Float @default(70.0) // e.g. 70 means locksmith gets 70%, manager gets 30%

  // Override platform commission % for this member's jobs (null = use platform default)
  platformCommissionOverride Float?

  role     String  @default("member") // "owner" | "member"
  isActive Boolean @default(true)

  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?

  @@unique([companyId, locksmithId])
}

// Locksmith/Technician model
model Locksmith {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  companyName   String?
  email         String  @unique
  phone         String
  passwordHash  String? // For login
  profileImage  String?
  profilePhotoVerified   Boolean @default(false) // True once AI face check passes
  profilePhotoVerifiedAt DateTime? // When face check passed
  profilePhotoRejectionReason String? // Why AI rejected the photo (if any)
  profilePhotoAiConfidence    Float?  // AI face verification confidence 0–1
  rating        Float   @default(5.0)
  totalJobs     Int     @default(0)
  totalEarnings Float   @default(0)
  isVerified    Boolean @default(false)
  isActive      Boolean @default(true)

  // Team account linkage (via join table)
  teamMemberships LocksmithCompanyMember[] @relation("TeamMemberships")
  ownedCompanies  LocksmithCompany[]       @relation("CompanyOwner")
  teamRole        String                   @default("solo") // "solo" | "owner" | "member"
  licenseNumber   String?
  insuranceNumber String?
  coverageAreas   String[] // Postcodes they cover (legacy)
  services        String[] // Types of services offered
  yearsExperience Int                      @default(0)

  // Location & Coverage (radius-based)
  baseLat        Float? // Base location latitude
  baseLng        Float? // Base location longitude
  baseAddress    String? // Human-readable base address
  coverageRadius Int?    @default(10) // Coverage radius in miles

  // Pricing - Assessment Fee (required for auto-dispatch)
  defaultAssessmentFee Float? // Locksmith's default assessment fee (e.g., 29.00)
  // Must be set for auto-dispatch eligibility

  // Stripe Connect
  stripeConnectId        String? // Stripe Connect account ID
  stripeConnectOnboarded Boolean @default(false)
  stripeConnectVerified  Boolean @default(false)

  // Notification preferences
  smsNotifications   Boolean @default(true) // Receive SMS for new jobs
  emailNotifications Boolean @default(true) // Receive email notifications
  pushNotifications  Boolean @default(true) // Receive push notifications

  // Availability status for receiving job notifications
  isAvailable            Boolean   @default(true) // When ON, locksmith receives job notifications
  lastAvailabilityChange DateTime? // Track when availability was last changed

  // Scheduled availability (working hours)
  scheduleEnabled   Boolean  @default(false) // Enable automatic availability schedule
  scheduleTimezone  String   @default("Europe/London") // Timezone for schedule
  scheduleStartTime String? // Start time in HH:MM format (e.g., "08:00")
  scheduleEndTime   String? // End time in HH:MM format (e.g., "20:00")
  scheduleDays      String[] // Days of week: ["monday", "tuesday", "wednesday", "thursday", "friday"]
  // Per-day schedule: { mon: { enabled: true, start: "08:00", end: "18:00" }, tue: {...}, ... }
  // Keys: mon tue wed thu fri sat sun
  scheduleWeekly    Json?    // Replaces/extends scheduleDays+Start/End with per-day hours
  scheduleOverridden Boolean @default(false) // True when locksmith manually went offline mid-shift; auto-cleared at shift end

  // Bot registration for direct messaging
  telegramChatId       String? // Telegram chat ID for bot notifications
  whatsappChatId       String? // WhatsApp chat ID for bot notifications
  preferredBotPlatform String? // "telegram" or "whatsapp"

  // Native Push Notifications (APNs / FCM via expo-notifications)
  nativeDeviceToken       String? // Raw APNs (iOS) or FCM (Android) device token
  nativeTokenType         String? // "apns" | "fcm" | "fcmv1"
  nativeTokenPlatform     String? // "ios" | "android"
  nativeTokenRegisteredAt DateTime? // When the native token was last registered

  // PWA Web Push (browser-installed Progressive Web App, separate from native app)
  webPushSubscription   String?   // JSON: { endpoint, keys: { p256dh, auth } }
  webPushPlatform       String?   // OS hint derived from User-Agent: "ios" | "android" | "desktop"
  webPushRegisteredAt   DateTime? // When the web-push subscription was last saved

  // Onboarding & Terms
  termsAcceptedAt          DateTime? // When locksmith accepted T&C
  onboardingCompleted      Boolean   @default(false)
  onboardingLastInteractionAt DateTime? // Last interaction relevant to onboarding reminders
  firstLocksmithLoginAt    DateTime? // First successful locksmith login (for one-time post-login onboarding email)
  insuranceDocumentUrl     String? // Uploaded insurance document
  certificationDocumentUrl String? // Uploaded locksmith certification
  additionalDocumentUrls   String[] // Any additional supporting documents
  documentationUploadedAt  DateTime? // When documentation was uploaded

  // Insurance expiry tracking
  insuranceExpiryDate   DateTime? // When insurance certificate expires
  insuranceVerifiedAt   DateTime? // When admin/AI verified the insurance
  insuranceVerifiedById String? // Admin ID who verified (null = AI auto-verified)
  insuranceStatus       String    @default("pending") // pending, pending_review, verified, expired, expiring_soon, unreadable
  insuranceReminderSent Boolean   @default(false) // Track if expiry reminder was sent
  insuranceVerificationNotes String? // AI notes when confidence < threshold
  insuranceAiConfidence Float?    // AI confidence score 0–1 from vision check

  // DBS (Disclosure and Barring Service) check
  // certificationDocumentUrl (see above) is the DBS certificate URL
  dbsStatus            String    @default("pending") // pending, pending_review, verified, expired, expiring_soon, unreadable
  dbsExpiryDate        DateTime? // DBS certificate expiry (typically 3 years)
  dbsVerifiedAt        DateTime? // When admin/AI verified the DBS
  dbsVerifiedById      String?   // Admin ID who verified (null = AI auto-verified)
  dbsReminderSent      Boolean   @default(false)
  dbsVerificationNotes String?   // AI notes when confidence < threshold
  dbsAiConfidence      Float?    // AI confidence score 0–1 from vision check

  // Password reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Dynamic commission tier
  commissionRate           Float     @default(0.25) // Work quote commission (e.g. 0.25 = 25%)
  commissionAssessmentRate Float     @default(0.15) // Assessment fee commission (e.g. 0.15 = 15%)
  commissionTier           String    @default("STANDARD") // STANDARD | PREMIUM
  commissionTierUpdatedAt  DateTime?
  commissionTierReasons    String[] // e.g. ["high_earner", "regular_area", "area_saturation"]
  commissionOverride       Boolean   @default(false) // If true, cron will not auto-update this locksmith's tier

  // Performance scoring
  acceptanceRate      Float     @default(1.0) // % of job offers accepted (0.0–1.0)
  avgResponseMinutes  Float     @default(5.0) // Historical average response time to new job alerts
  onTimeRate          Float     @default(1.0) // % of ETAs met within 15 min buffer
  performanceScore    Float     @default(75.0) // Composite score 0–100 fed into dispatch priority
  performanceScoredAt DateTime? // When score was last computed

  createdAt      DateTime @default(now())
  // Referral system
  referralCode   String? // Their own shareable code - sparse unique index managed in Atlas
  referredByCode String? // Code they signed up with

  updatedAt DateTime @updatedAt

  jobs             Job[]
  quotes           Quote[]
  applications     LocksmithApplication[]
  payouts          Payout[]
  reviews          Review[]

  auctionsAccepted JobAuction[]

  // Per-postcode-district coverage rows used by the ad-campaign gate
  // (campaigns can only run in districts where some locksmith covers + has
  // capacity). Distinct from the legacy `coverageAreas: String[]` and the
  // radius-based dispatch — this is structured for ad-targeting decisions.
  coverages LocksmithCoverage[]

  // Stripe onboarding reminder log relation
  stripeReminderLogs StripeReminderLog[]
  baseLocationReminderLogs BaseLocationReminderLog[]
  appInstallReminderLogs AppInstallReminderLog[]

  // Performance indexes for dispatch / matcher queries (Locksmith lookups by
  // active+available status combined with base location). MongoDB B-tree
  // compound indexes; bounding-box pre-filtering is still done in JS, but
  // these greatly reduce the candidate set scanned per dispatch.
  @@index([isActive, isAvailable])
  @@index([baseLat, baseLng])
  @@index([telegramChatId])
  @@index([whatsappChatId])
}

// ─────────────────────────────────────────────────────────────────────────────
// LocksmithCoverage — structured per-postcode-district coverage with capacity.
//
// WHY THIS EXISTS:
//   The ad-campaign creation flow needs a single, fast answer to "does any
//   onboarded locksmith cover postcode district X with free capacity right
//   now?" — to gate non-London campaigns against operational reality.
//   Existing radius-based dispatch can answer "is a locksmith near GPS
//   coordinates X?" but that's the wrong shape for ad-targeting decisions
//   which are made per postcode district (RG1, SK4, MK9, …) hours or days
//   before any specific job.
//
// HOW IT'S POPULATED:
//   - Backfill script reads Locksmith.baseLat/baseLng + coverageRadius and
//     computes which UK postcode districts fall within radius. These rows
//     are tagged source="radius_backfill" with a confidence < 1.0 so admins
//     can review and override.
//   - Legacy Locksmith.coverageAreas[] entries import as source="manual".
//   - Admin UI at /admin/locksmiths/coverage lets ops set capacity per row
//     and toggle isPaused (vacations, sickness, training).
//
// HOW CAPACITY IS CHECKED:
//   currentLoad is NOT stored — it's computed live as
//   `Job.count({ locksmithId, createdAt >= now-7d, postcode startsWith district })`
//   to avoid drift. weeklyCapacity - currentLoad = free slots.
// ─────────────────────────────────────────────────────────────────────────────
model LocksmithCoverage {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  locksmithId String    @db.ObjectId
  locksmith   Locksmith @relation(fields: [locksmithId], references: [id], onDelete: Cascade)

  // UK postcode district (the outward-code, e.g. "RG1", "SK4", "MK9", "WD3").
  // Always uppercase, no internal spaces. Matches the natural granularity of
  // Google Ads location targeting and our hyper-local keyword universe.
  postcodeDistrict String

  // Denormalised city/region/county for admin grouping. Not used in matching
  // — postcodeDistrict is the source of truth — but lets the coverage UI
  // group rows like "Manchester (M1, M2, M3...)" without an extra lookup.
  city   String?
  region String?

  // How many jobs/week this locksmith can take in this district. Defaults to
  // 5 (a modest starting point); admins should adjust based on each
  // locksmith's stated capacity and the district's typical job volume.
  weeklyCapacity Int @default(5)

  // Manual override flag — used for vacations, sickness, training, capacity
  // reductions, voluntary pauses. When true the campaign gate treats this
  // coverage row as absent regardless of weeklyCapacity.
  isPaused        Boolean   @default(false)
  pauseReason     String?
  pausedUntil     DateTime?

  // Provenance for trustworthiness. Manual entries from the admin UI are
  // worth more than radius-based inferences.
  source          String  @default("manual") // "manual" | "radius_backfill" | "legacy_array_import"
  confidenceScore Float   @default(1.0)      // 0.0–1.0; backfilled rows start at 0.7

  // When ops last confirmed this row is still accurate. Lets us nag for
  // re-confirmation after N days (planned: cron job that pings locksmiths
  // every 60 days to confirm their stated districts).
  lastConfirmedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One row per (locksmith, district). The unique constraint prevents
  // accidental duplicates from backfill re-runs.
  @@unique([locksmithId, postcodeDistrict])
  // Hot path: "which locksmiths cover district X right now?"
  @@index([postcodeDistrict, isPaused])
  @@index([locksmithId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SharkDomain — known UK locksmith scam-pattern domains.
//
// WHY THIS EXISTS:
//   The anti-shark thesis: shark domains dominate generic high-intent
//   terms (emergency locksmith, locked out, locksmith near me). When 3+
//   shark domains appear in a SERP for a keyword, the auction is
//   structurally rigged against an honest operator — even if you bid
//   competitively, the on-site shark playbook (low call-out bait → £400+
//   upsell) lets sharks sustain higher CPC than your honest model can.
//
//   This model lets competitor-intel flag those keywords and the
//   opportunity scout deprioritise them, regardless of headline CPC.
//
//   Domains are seeded from operations-team research + auto-flagged via
//   competitor-intel's fingerprint signals (no MLA + national bidding +
//   call-centre-style copy + suspicious price anchors like "£49 from").
//
// USAGE:
//   const sharks = await prisma.sharkDomain.findMany({ where: { isActive: true } });
//   const sharkSet = new Set(sharks.map(s => s.domain));
//   const sharkAdsInSerp = ad.serpDomains.filter(d => sharkSet.has(d)).length;
//   if (sharkAdsInSerp >= 3) markKeywordSharkSaturated();
// ─────────────────────────────────────────────────────────────────────────────
model SharkDomain {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Bare domain (no protocol, no www, lowercase). "lockforce.co.uk" etc.
  // Indexed for the hot-path "is this domain a shark?" lookup.
  domain String @unique

  // Free-text label shown in admin UI: "Emergency Locksmith UK (call-centre)"
  label String?

  // Which signals flagged this as a shark. Free-text array so we can add
  // new patterns over time without a schema migration. Common values:
  //   "no_mla"             — claims MLA badge or no MLA membership at all
  //   "no_dbs"             — no DBS-checked claim
  //   "national_call_centre" — non-locksmith middleman dispatcher
  //   "suspect_pricing"    — "from £29" / "£49 callout" bait pattern
  //   "fake_reviews"       — review-mill pattern detected
  //   "brand_parasite"     — rides on Yale/Banham brand SEO
  //   "manual_research"    — added by ops based on customer complaints
  patterns String[] @default([])

  // Optional supporting evidence — links to BBC/Which? exposés, Trading
  // Standards reports, Trustpilot review aggregations, etc. Helps ops
  // justify the flag if a domain disputes its inclusion.
  evidenceUrls String[] @default([])

  // Lifecycle. Soft-disable rather than delete — once a domain is flagged
  // and we have spend data confirming it suppresses our ROI, we want a
  // permanent audit trail. Toggle isActive=false if a previously-flagged
  // operator demonstrably cleans up (rare but possible).
  isActive   Boolean   @default(true)
  source     String    @default("manual") // "manual" | "auto_fingerprint" | "import_research"
  notes      String?

  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime?  // when competitor-intel last observed this domain in a SERP
  seenCount   Int        @default(0)  // total SERPs we've observed this domain in

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// Locksmith application for a job (when locksmith applies with assessment fee)
model LocksmithApplication {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  jobId String @db.ObjectId
  job   Job    @relation(fields: [jobId], references: [id])

  locksmithId String    @db.ObjectId
  locksmith   Locksmith @relation(fields: [locksmithId], references: [id])

  assessmentFee Float // Fee the locksmith is charging
  callOutFee    Float? // Call-out fee for emergency workflow
  eta           Int // Minutes until arrival
  estimatedETA  String? // Human-readable ETA (e.g., "15 minutes")
  message       String? // Optional message to customer

  status String @default("pending") // pending, accepted, rejected

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, locksmithId])
}

// Main Job model - the core entity
model Job {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  jobNumber String @unique // Human-readable job number

  status JobStatus @default(PENDING)

  // Source tracking (phone/web/app)
  createdVia         String  @default("web") // web, phone, app, retell_ai
  retellCallId       String? // Retell AI call ID for voice-initiated jobs
  phoneCollectedData Json? // Data collected during phone call
  continueToken      String? // Token for continuing phone-initiated request (uniqueness enforced at application level)

  // Marketing attribution — populated at booking time from the
  // UserSession the visitor arrived in. These let us:
  //   1. Compute per-campaign cost-per-booked-job (rip-off-defence cron)
  //   2. Upload conversions to Google Ads via the Conversions API using
  //      the original gclid — so Google bids on real outcomes, not vanity
  //      clicks. This is the single biggest defence against being ripped
  //      off by Google's auction.
  utmSource     String?  // "google" | "facebook" | "meta" | "direct" | …
  utmMedium     String?  // "cpc" | "organic" | "email" | …
  utmCampaign   String?  // The campaign name in our ad tool
  utmContent    String?  // Ad/creative identifier
  utmTerm       String?  // Keyword (if exposed by the platform)
  gclid         String?  // Google Click ID — required by Google's Conversions API
  fbclid        String?  // Facebook Click ID — for Meta Conversions API
  landingPage   String?  // First page the visitor landed on
  // Conversion upload bookkeeping — when COMPLETED+paid, the upload-cron
  // sends the conversion event back to Google. These columns mark whether
  // that succeeded, when, and the upload error if any.
  conversionUploadedAt    DateTime?
  conversionUploadStatus  String?    // "pending" | "uploaded" | "failed" | "skipped_no_gclid"
  conversionUploadError   String?

  // Emergency workflow tracking
  isEmergency          Boolean   @default(false) // Whether this is an emergency request
  emergencyDetails     String? // Details of the emergency
  exactLocation        String? // Exact location description (e.g., "blue door, flat 3")
  notifiedLocksmithIds String[] // IDs of locksmiths who were notified
  notifiedAt           DateTime? // When locksmiths were notified

  // Admin: "no locksmith available in coverage area" notification
  noLocksmithNotifiedAt       DateTime?
  noLocksmithNotifiedChannels String[]  @default([]) // ["sms","email"]
  noLocksmithNotifiedBy       String? // admin email/id who triggered it

  // Customer info
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])

  // Locksmith info (assigned after acceptance)
  locksmithId String?    @db.ObjectId
  locksmith   Locksmith? @relation(fields: [locksmithId], references: [id])

  // Job details
  problemType  String // lockout, broken, key-stuck, etc.
  propertyType String // house, flat, commercial, car
  description  String?

  // Location
  postcode  String
  address   String
  latitude  Float?
  longitude Float?

  // Assessment fee
  assessmentFee  Float   @default(29.00)
  assessmentPaid Boolean @default(false)
  acceptedEta    Int? // ETA in minutes that was agreed upon

  // Timestamps for workflow
  createdAt        DateTime  @default(now())
  acceptedAt       DateTime?
  enRouteAt        DateTime? // When locksmith started heading to location
  estimatedArrival String? // ETA as string (e.g., "15 minutes", "30 mins")
  arrivedAt        DateTime?
  diagnosedAt      DateTime?
  workStartedAt    DateTime?
  workCompletedAt  DateTime?
  signedAt         DateTime?

  // GPS tracking for all events (anti-fraud protection)
  requestGps     Json? // { lat, lng, accuracy } - Customer's location when requesting
  acceptedGps    Json? // { lat, lng, accuracy } - Locksmith's location when accepting
  arrivalGps     Json? // { lat, lng, accuracy } - Locksmith's location when arriving
  quoteGps       Json? // { lat, lng, accuracy } - Locksmith's location when sending quote
  workStartedGps Json? // { lat, lng, accuracy } - Locksmith's location when starting work
  completionGps  Json? // { lat, lng, accuracy } - Locksmith's location when completing
  signatureGps   Json? // { lat, lng, accuracy } - Customer's location when signing

  // Photos
  photos Photo[]

  // Quote
  quote Quote?

  // Digital signature
  signature Signature?

  // Final report
  report Report?

  // Applications from locksmiths
  applications LocksmithApplication[]

  // Payments
  payments Payment[]

  // Review
  review Review?

  // B2B / Landlord linkage
  organisationId String?       @db.ObjectId
  organisation   Organisation? @relation("OrgJobs", fields: [organisationId], references: [id])
  propertyId     String?       @db.ObjectId
  property       Property?     @relation("PropertyJobs", fields: [propertyId], references: [id])

  // Auction (for high-supply areas)
  auction JobAuction?

  // In-platform chat
  messages JobMessage[]

  // Scheduled booking support
  scheduledFor DateTime? // If set, job is a pre-booked appointment
  isScheduled  Boolean   @default(false)

  // Auto re-dispatch tracking
  dispatchAttempts Int       @default(1) // How many notification waves have been sent
  lastDispatchAt   DateTime? // When the last dispatch wave was sent

  // Review request automation
  reviewRequestedAt DateTime? // When review request was sent to customer

  // Win-back automation
  winBackSentAt DateTime? // When post-job win-back email was sent

  // Confirmation deadline for customer to sign (locksmith safety)
  confirmationDeadline      DateTime? // When customer must sign by
  confirmationRemindersSent Int       @default(0) // Number of reminders sent
  autoCompletedAt           DateTime? // If job was auto-completed after deadline

  // Metadata
  updatedAt DateTime @updatedAt

  @@index([continueToken])
  // Frequently-filtered Job queries (dispatch, dashboard, lifecycle crons)
  @@index([status])
  @@index([status, createdAt])
  @@index([locksmithId, status])
  @@index([customerId, createdAt])
  @@index([createdAt])
  @@index([scheduledFor])
  @@index([confirmationDeadline])
}

// Job status enum
enum JobStatus {
  PHONE_INITIATED // Phone call started, awaiting web completion
  PENDING // Customer submitted, waiting for locksmith
  SCHEDULED // Pre-booked appointment — not yet dispatched
  ACCEPTED // Locksmith accepted the job
  EN_ROUTE // Locksmith is on the way
  ARRIVED // Locksmith arrived at location
  DIAGNOSING // Locksmith performing diagnostic
  QUOTED // Quote sent to customer
  QUOTE_ACCEPTED // Customer accepted quote
  QUOTE_DECLINED // Customer declined quote (assessment only)
  IN_PROGRESS // Work being performed
  PENDING_CUSTOMER_CONFIRMATION // Work finished, waiting for customer to confirm & sign
  COMPLETED // Work finished and customer confirmed
  SIGNED // Customer signed off and payment processed
  CANCELLED // Job cancelled
}

// Quote model
model Quote {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  jobId String @unique @db.ObjectId
