  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ============================================================================
// META (FACEBOOK) CATALOG — service-intent catalog for dynamic ads.
// Drives /api/meta/catalog-feed and the admin sync to Meta Graph API.
// ============================================================================

// Per-slug overrides for the static service catalog. The default copy lives in
// `src/lib/services-catalog.ts`; this model only stores admin overrides such
// as a custom-uploaded image and per-item Meta sync state.
model ServiceCatalogItem {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  slug              String    @unique // matches ServiceSlug in code
  imageUrl          String? // custom uploaded image (Vercel Blob URL); overrides dynamic OG
  customTitle       String?
  customDescription String?
  // Meta Catalog sync state
  metaProductId     String? // returned product id once synced
  metaRetailerId    String? // retailer_id we sent (== slug)
  lastSyncedAt      DateTime?
  lastSyncStatus    String? // "success" | "error"
  lastSyncMessage   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Intent SEO landings — DB-backed CMS overrides for static intent content.
// Source of truth at runtime: DB rows merged on top of the static seed in
// `src/lib/intent-landings.ts`. Admin edits write here and call
// `revalidatePath('/intent/[slug]')` so the SSG page regenerates.
// ─────────────────────────────────────────────────────────────────────────────
model IntentLanding {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  slug          String   @unique
  title         String
  pillarKeyword String?
  intentTags    String[] @default([])
  isActive      Boolean  @default(true)
  position      Int      @default(0)
  /// Full IntentLanding content (matches src/lib/intent-landing.ts shape).
  /// Stored as a single JSON document so the admin form can ship blocks/FAQs
  /// /A-B copy together without flattening to dozens of columns.
  content       Json
  updatedBy     String? // admin id who last touched it
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, position])
}

// ─────────────────────────────────────────────────────────────────────────────
// Keyword-driven SEO templates. Each row defines one high-CPC keyword
// pattern (e.g. "locksmith-near-me", "emergency-locksmith-near-me") and
// auto-generates one landing page per UK city at
// `/{keywordSlug}-in-{citySlug}`. Token interpolation: {city}, {region},
// {county}, {areas}, {landmarks}, {response}, {population}.
// ─────────────────────────────────────────────────────────────────────────────
model KeywordTemplate {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  /// Lowercase kebab keyword stem, e.g. "locksmith-near-me".
  slug           String   @unique
  /// Human label, e.g. "Locksmith Near Me".
  label          String
  /// Pillar keyword grouping (matches PILLAR_KEYWORDS).
  pillarKeyword  String?
  intentTags     String[] @default([])
  isActive       Boolean  @default(true)
  position       Int      @default(0)
  /// "all" → every UK city; "selected" → only `selectedCities`.
  citiesMode     String   @default("all")
  selectedCities String[] @default([])
  /// Title / meta / hero / body templates with token placeholders.
  content        Json
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive, position])
}

// Singleton-ish config for the connected Meta Commerce catalog. The first row
// with `isActive = true` is treated as the active configuration.
model MetaCatalogConfig {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  catalogId           String // FB catalog id (numeric string)
  catalogName         String?
  feedId              String? // optional scheduled-feed id pointing at /api/meta/catalog-feed
  feedUrl             String?
  isActive            Boolean   @default(true)
  lastFullSyncAt      DateTime?
  lastFullSyncStatus  String? // "success" | "error" | "partial"
  lastFullSyncMessage String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// Cache mapping from a set of service catalog slugs to a Meta Product Set id.
// Reused so we don't re-create the same product_set on every campaign launch.
model ServiceCatalogProductSet {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  catalogId    String // FB catalog id this product_set belongs to
  productSetId String   @unique // FB product_set id
  name         String
  /// Sorted, comma-joined slug list — used as a stable lookup key.
  slugsKey     String   @unique
  slugs        String[] // raw slug array, mirrors slugsKey
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([catalogId])
}

// Per-action audit row written by the Meta optimiser (and other agent loops).
// Keeps a forensic trail of WHY an automated action was taken — including the
// policy snapshot at decision time and whether the action was actually
// executed (live) or merely proposed (dryRun).
model AgentDecision {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  agent          String // "cmo" | "meta-optimiser" | "ads-specialist" | etc.
  platform       String // "meta" | "google"
  action         String // "pause_ad" | "scale_adset" | "rotate_creative" | "exclude_converters"
  /// Free-form context — adId/adSetId/campaignId, metric snapshot, reasoning.
  payload        Json
  /// Frozen `MarketingPolicy` view used for the decision. Lets us re-evaluate
  /// historical actions even after the policy is changed.
  policySnapshot Json
  dryRun         Boolean   @default(true)
  /// Outcome of execution — "ok", "blocked_by_policy", "blocked_by_spend", "error", or null when dryRun.
  outcome        String?
  outcomeMessage String?
  executedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([agent, createdAt])
  @@index([platform, action, createdAt])
}

// ==========================================
// AGENT REFLECTION / SELF-LEARNING
// ==========================================

// Post-execution reflection on an agent decision or output.
// Outcome (WIN/LOSS/INCONCLUSIVE/NEUTRAL) is graded deterministically from
// downstream metrics; for non-inconclusive cases the REASONING LLM tier writes
// the narrative + lessons. Lessons feed back into AgentMemory for the next
// heartbeat.
model AgentReflection {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  agentName   String // "opportunity-scout" | "ads-specialist" | "copywriter" | ...
  subjectType String // "opportunity" | "draft" | "campaign" | "adset" | "ad" | "pause-action"
  subjectId   String // loose FK to whatever was decided about

  decisionId  String? @db.ObjectId // optional FK to AgentDecision
  executionId String? @db.ObjectId // optional FK to AgentExecution

  windowDays Int    @default(28) // 7 | 14 | 28
  outcome    String // "WIN" | "LOSS" | "INCONCLUSIVE" | "NEUTRAL"
  metric     String // "roas" | "cpa" | "ctr" | "conversionRate" | "score_accuracy"

  expectedValue Float?
  actualValue   Float?
  delta         Float?
  confidence    Float  @default(0.5) // 0-1, computed from sample size

  narrative String? // REASONING-tier LLM output (WIN/LOSS only)
  lessons   String[] // bullet list distilled from narrative

  appliedAt DateTime? // when lessons were written into AgentMemory

  computedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([agentName, computedAt])
  @@index([subjectType, subjectId])
  @@index([outcome, computedAt])
}

// Adaptive seed bank for Opportunity Scout (and future keyword-driven agents).
// Replaces the hardcoded BASELINE_SEEDS array. Each row tracks its own
// performance and is re-ranked by the reflection cron.
model KeywordSeed {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  keyword  String @unique
  category String @default("baseline") // "baseline" | "learned" | "competitor" | "experimental"

  score              Float @default(1.0) // Wilson-ish (winCount+1) / (winCount+lossCount+2)
  winCount           Int   @default(0)
  lossCount          Int   @default(0)
  inconclusiveCount  Int   @default(0)
  usageCount         Int   @default(0)

  lastUsedAt DateTime?
  lastWinAt  DateTime?
  lastLossAt DateTime?

  firstSeenSource String? // "baseline" | "learnings:gads:90d" | "reflection:opp-bristol" | ...
  isActive        Boolean @default(true)
  notes           String?

  // ── Keyword stability / aging ──────────────────────────────────────────
  // Tracks how consistently a keyword appears in Planner scans with positive
  // profit. A keyword that appeared once at £12/click could be a seasonal
  // spike or broad-match noise. One that has appeared 6 consecutive scans
  // with stable profit is a durable opportunity.
  //
  // stabilityWeight: 0.25 (first scan) → 1.0 after 4+ consecutive survival scans.
  // Applied as a multiplier to profitPerClick in the scorer so new/volatile
  // keywords are discounted until they prove consistent.

    // First time this keyword was returned by a Keyword Planner scan (not when it was added as a seed).
  firstScannedAt           DateTime?
    // Most recent Planner scan where this keyword appeared.
  lastScannedAt            DateTime?
    // Total number of Planner scans in which this keyword appeared.
  scanCount                Int       @default(0)
    // Consecutive scans where keyword appeared with profitPerClick > 0.
  // Resets to 0 on first unprofitable scan.
  consecutiveSurvivalCount Int       @default(0)
    // Rolling last-8 profitPerClick readings from Planner scans (GBP per click).
  // Used to compute volatilityScore. Stored as Float[] (oldest first).
  profitHistory            Float[]
    // Standard deviation of profitHistory.
  // 0 = perfectly stable; high = volatile / spike-driven.
  // Applied as a discount: effectiveProfitPerClick × (1 / (1 + volatilityScore)).
  volatilityScore          Float     @default(0)
    // Combined stability weight: min(1, consecutiveSurvivalCount / 4) × volatilityDiscount.
  // New seeds start at 0.25. Stable seeds reach 1.0 after 4+ profitable scans.
  // Volatile seeds stay below 1.0 regardless of survival count.
  stabilityWeight          Float     @default(0.25)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, score])
  @@index([category])
}

// =========================================================================
// Geo-local keyword performance — ISOLATED from the global KeywordSeed score.
//
// Problem: a keyword that converts at 18% in Sheffield cannot be assumed to
// convert at 18% in a rural Lincolnshire market town. Global seed scores
// propagate learning across all geos, so weak regions poison strong ones.
//
// This table stores per-(keyword × geo) scan history and a local score that
// is ONLY updated from that geo's scan results. The scorer uses the local
// score when available; falls back to the global KeywordSeed score otherwise.
//
// One row per unique (keyword, geoId) pair. No FK to KeywordSeed — the
// keyword is stored as a plain string for resilience (seeds can be deleted).
// =========================================================================
model KeywordGeoScore {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  keyword String
  geoId   String

  // Local performance (isolated to this geo only)
  localScore    Float   @default(1.0) // Wilson-ish: (localWins+1)/(localWins+localLosses+2)
  localWinCount Int     @default(0)
  localLossCount Int    @default(0)

  // Local scan history
  scanCount       Int     @default(0)
  profitHistory   Float[] // rolling last-6 profitPerClick readings for this geo
  volatilityScore Float   @default(0)
  stabilityWeight Float   @default(0.25)

  // Last profitable scan profit (used to weight the geo score vs global score)
  lastProfitPerClick Float?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime?

  @@unique([keyword, geoId])
  @@index([geoId, localScore])
  @@index([keyword])
}

// =========================================================================
// Geo-level operational efficiency metrics.
//
// The profit model scores: searches × (convRate × jobValue - CPC).
// But this is MATHEMATICAL profit, not OPERATIONAL profit.
//
// A geo with a 25% spam lead rate, 20% missed call rate, and 15% dispatch
// failure rate has an effective operational efficiency of:
//   (1 - 0.25) × (1 - 0.20) × (1 - 0.15) ≈ 0.51
// meaning only 51p in every modelled £1 of profit is actually realised.
//
// All fields are nullable — null means "no data yet, assume 1.0."
// The operationalEfficiencyFactor is pre-computed when fields are populated
// and applied as a multiplier to expectedMonthlyProfitGbp in the scorer.
//
// Populated by: job outcome sync from LockSafe platform, call-tracking
// analytics, fraud/spam detection, dispatch log analysis.
// =========================================================================
model GeoOperationalMetrics {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  geoId String
  label String

  // ── Lead quality ─────────────────────────────────────────────────────────
    // Fraction of inbound leads that are spam, fake, or test entries (0–1).
  spamLeadRate Float?
    // Fraction of leads that are duplicates of a lead seen in the last 30 days (0–1).
  duplicateLeadRate Float?

  // ── Dispatch / operations ─────────────────────────────────────────────────
    // Fraction of dispatched leads where a locksmith was successfully assigned (0–1).
  dispatchSuccessRate Float?
    // Fraction of booked jobs cancelled before completion (0–1).
  cancellationRate Float?

  // ── Revenue quality ───────────────────────────────────────────────────────
    // Fraction of calls that go unanswered (affects conversion from click to lead) (0–1).
  missedCallRate Float?
    // Fraction of completed jobs that result in a refund or dispute (0–1).
  refundProbability Float?

  // ── Derived ───────────────────────────────────────────────────────────────
    // Operational efficiency factor — pre-computed product of all non-null metrics.
  // = (1 - spamLeadRate) × dispatchSuccessRate × (1 - cancellationRate)
  // × (1 - missedCallRate) × (1 - refundProbability) × (1 - duplicateLeadRate)
  // Null until at least one metric is populated. Applied as a discount to
  // expectedMonthlyProfitGbp. A fully-efficient geo scores 1.0.
  operationalEfficiencyFactor Float?

    // Number of leads/jobs used to compute the above metrics.
  sampleSize Int?
    // Date range these metrics cover (ISO string, e.g. "2026-01-01/2026-04-30").
  samplePeriod String?

  lastComputedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([geoId])
}

// ==========================================
// COMPETITOR INTELLIGENCE
// ==========================================

  // A competitor domain we actively monitor via SEMrush + SpyFu.
  // Admins can add/remove domains; the competitor-intel agent reads this list.
model CompetitorDomain {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  domain String @unique  // e.g. "lockforce.co.uk"
  label  String          // e.g. "Lockforce (national franchise)"

    // Is monitoring active? Admins can pause individual domains.
  isActive Boolean @default(true)

    // Approximate monthly PPC spend (£) — SEMrush estimate, updated each scan.
  estimatedMonthlySpendGbp Float?

    // Last time the agent successfully scanned this domain.
  lastScannedAt DateTime?

    // ISO country code for the primary market (default "GB").
  countryCode String @default("GB")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  keywords   CompetitorKeyword[]
  adCopies   CompetitorAdCopy[]
  geoSignals CompetitorGeoSignal[]

  @@index([isActive])
}

  // A single paid keyword attributed to a competitor domain.
  // "dualSource" = keyword confirmed by BOTH SEMrush AND SpyFu →
  // higher confidence it's a live, intentional bid (not sampling noise).
  // Graduated keywords (passedQualityGate=true) are written to the seed bank
  // with category="competitor". They only stay in the seed bank while they
  // remain active — if a competitor drops the keyword, we mark it inactive
  // and the seed bank score decays naturally.
model CompetitorKeyword {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  domainId   String @db.ObjectId
  domain     CompetitorDomain @relation(fields: [domainId], references: [id])

  keyword    String
    // ISO country code this keyword was fetched for (usually "GB").
  countryCode String @default("GB")

    // Average CPC (£) as estimated by SEMrush.
  cpcGbp     Float?
    // Estimated monthly clicks.
  monthlyClicks Int?
    // Average position (1–4 for ads).
  avgPosition  Float?

    // SEMrush competition index 0–100.
  competitionIndex Int?

    // Seen in SEMrush data.
  seenInSemrush Boolean @default(false)
    // Seen in SpyFu data.
  seenInSpyFu   Boolean @default(false)

    // True when both SEMrush AND SpyFu reported this keyword in the same scan.
  // Dual-source keywords are treated as high-confidence seeds.
  dualSource Boolean @default(false)

    // Passed the locksmith relevance filter AND profitPerClick > 0 check.
  passedQualityGate Boolean @default(false)

    // Whether the competitor is currently actively bidding (vs. historical).
  isActive Boolean @default(true)

    // When we first saw this competitor bidding on this keyword.
  firstSeenAt DateTime @default(now())
    // When we last confirmed the competitor is still bidding.
  lastConfirmedAt DateTime?
    // When the competitor stopped bidding (if detected).
  droppedAt DateTime?

  @@unique([domainId, keyword, countryCode])
  @@index([domainId, isActive])
  @@index([keyword, isActive])
  @@index([dualSource, passedQualityGate])
}

  // A competitor ad copy snapshot (headline + descriptions).
  // Used to identify messaging angles and USPs we're not covering.
  // Multiple copies per domain — stored as rolling history so we can see
  // when competitors change messaging (e.g. moving from price to trust).
model CompetitorAdCopy {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  domainId String @db.ObjectId
  domain   CompetitorDomain @relation(fields: [domainId], references: [id])

    // The keyword(s) this ad appeared for.
  triggerKeyword String

  headline1    String?
  headline2    String?
  headline3    String?
  description1 String?
  description2 String?

    // Estimated CTR for this ad (SEMrush estimate).
  estimatedCtr Float?

    // Display URL path components.
  displayPath1 String?
  displayPath2 String?

    // SEMrush / SpyFu source.
  source String @default("semrush")

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime?

    // Still appearing in current scans.
  isActive Boolean @default(true)

  @@index([domainId, triggerKeyword])
  @@index([domainId, isActive])
}

  // Per-competitor per-city presence signal.
  // Tracks whether a competitor is ENTERING or EXITING a geo, which is a
  // leading indicator of market opportunity:
  // - Competitor EXITS a geo → reduced auction pressure → better ROI for us
  // - Competitor ENTERS a geo → increased pressure → review our bids
  // "presenceScore" = 0 (absent) → 1 (strong presence). Computed from
  // estimated impression share and number of active keywords in that geo.
model CompetitorGeoSignal {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  domainId String @db.ObjectId
  domain   CompetitorDomain @relation(fields: [domainId], references: [id])

    // Google Ads geo target constant ID (same IDs used in coverage universe).
  // E.g. "1006502" = Sheffield.
  geoId   String
  geoName String

    // 0–1 score representing how strongly this competitor is present in this geo.
  // Based on: estimated keywords × avg position × impression share proxy.
  presenceScore Float @default(0)

    // Estimated monthly ad spend in this geo (£). SEMrush estimate.
  estimatedSpendGbp Float?

    // Number of active paid keywords attributed to this geo.
  activeKeywordCount Int @default(0)

    // Trend vs. previous scan:
  // "ENTERING"  — presenceScore grew > 0.15 since last scan
  // "EXITING"   — presenceScore fell > 0.15 since last scan
  // "STABLE"    — no significant change
  // "NEW"       — first time we've seen this competitor in this geo
  trend String @default("STABLE")

    // Previous presenceScore (for trend computation).
  previousPresenceScore Float?

  firstSeenAt DateTime @default(now())
  lastUpdatedAt DateTime?

  @@unique([domainId, geoId])
  @@index([geoId, presenceScore])
  @@index([domainId, trend])
  @@index([trend])
}

// ==========================================
// REFERRAL SYSTEM
// ==========================================

// Tracks every referral link / code
model Referral {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Who made the referral
  referrerId   String @db.ObjectId
  referrerType String // "customer" | "locksmith"
  referrerName String

  // Unique share code (e.g. SARAH-X4K2)
  code String @unique

  // Who used the code (filled in on conversion)
  referredId    String? @db.ObjectId
  referredType  String? // "customer" | "locksmith"
  referredName  String?
  referredEmail String?

  // Status lifecycle
  status String @default("active") // active | converted | rewarded | expired

  // Rewards in GBP
  referrerReward Float @default(10.00) // credit added to referrer after conversion
  referredReward Float @default(10.00) // discount applied to referred's first job

  // Conversion tracking
  clickCount   Int       @default(0)
  convertedAt  DateTime?
  triggerJobId String?   @db.ObjectId // Job that completed and triggered reward

  // Reward paid out
  rewardedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerId, referrerType])
  @@index([status])
}

// ==========================================
// DISPUTE / CHARGEBACK SYSTEM
// ==========================================

model Dispute {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Stripe chargeback details
  stripeDisputeId       String  @unique
  stripeChargeId        String
  stripePaymentIntentId String?

  // Linked records
  jobId       String  @db.ObjectId
  customerId  String? @db.ObjectId
  locksmithId String? @db.ObjectId

  // Dispute details
  amount   Float
  currency String @default("gbp")
  reason   String // fraudulent | duplicate | product_not_received | unrecognized | credit_not_processed | general
  status   String // warning_needs_response | warning_under_review | warning_closed | needs_response | under_review | charge_refunded | won | lost

  // Evidence we have
  hasGpsData   Boolean @default(false)
  hasPhotos    Boolean @default(false)
  hasSignature Boolean @default(false)
  hasReport    Boolean @default(false)

  // Evidence packet (auto-generated PDF)
  evidencePacketUrl     String?
  evidencePacketBuiltAt DateTime?

  // Submission to Stripe
  submittedAt DateTime?
  submittedBy String? // Admin name who submitted

  // Response deadline (Stripe gives 7-21 days)
  dueBy DateTime?

  // Internal notes
  notes String?

  // Outcome
  outcome       String? // won | lost | withdrawn
  outcomeAt     DateTime?
  outcomeReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([jobId])
}

// ==========================================
// IN-PLATFORM JOB CHAT
// ==========================================

model JobMessage {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  jobId String @db.ObjectId
  job   Job    @relation(fields: [jobId], references: [id])

  // Sender details — one of these will be set
  customerId     String? @db.ObjectId
  locksmithId    String? @db.ObjectId
  isAdminMessage Boolean @default(false)

  // Sender type for display
  senderType String // "customer" | "locksmith" | "admin" | "system"
  senderName String

  body          String
  attachmentUrl String? // Optional image/file

  readAt DateTime? // When the recipient read it

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([createdAt])
}

// ==========================================
// B2B / LANDLORD ACCOUNTS
// ==========================================

model Organisation {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name         String
  type         String @default("landlord") // "landlord" | "letting_agency" | "property_manager" | "business"
  contactName  String
  contactEmail String @unique
  contactPhone String

  // Billing
  billingEmail String?
  vatNumber    String?

  // Contract / pricing
  contractedRate Float? // Fixed assessment fee agreed with org (overrides surge)
  creditBalance  Float  @default(0)
  paymentTerms   Int    @default(30) // Days to pay invoice (net-30 default)

  // Properties managed by this org
  properties Property[]

  // Members (linked Customer accounts)
  members OrgMember[]

  // Jobs raised under this org
  jobs Job[] @relation("OrgJobs")

  // Invoices issued to this org
  invoices OrgInvoice[]

  isActive Boolean @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model OrgMember {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  orgId String       @db.ObjectId
  org   Organisation @relation(fields: [orgId], references: [id])

  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])

  role    String   @default("member") // "owner" | "manager" | "member"
  addedAt DateTime @default(now())

  @@unique([orgId, customerId])
}

model Property {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  orgId String       @db.ObjectId
  org   Organisation @relation(fields: [orgId], references: [id])

  address   String
  postcode  String
  type      String  @default("residential") // "residential" | "commercial"
  reference String? // Internal property reference (e.g. flat number, portfolio code)

  // Jobs at this property
  jobs Job[] @relation("PropertyJobs")

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([postcode])
}

// ==========================================
// B2B INVOICING
// ==========================================

model OrgInvoice {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  orgId String       @db.ObjectId
  org   Organisation @relation(fields: [orgId], references: [id])

  invoiceNumber String @unique // e.g. INV-2025-01-0042

  period      String // ISO month string: "2025-01"
  periodStart DateTime
  periodEnd   DateTime

  jobIds   String[] @db.ObjectId
  jobCount Int

  subtotal  Float // Sum of assessmentFee for all jobs
  vatAmount Float @default(0)
  total     Float

  dueDate DateTime // periodEnd + paymentTerms days

  status String @default("sent") // "sent" | "paid" | "overdue" | "void"

  paidAt DateTime?
  pdfUrl String? // URL to stored PDF (future: Cloudflare R2 / S3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([status])
  @@index([period])
}

// ==========================================
// LOCKSAFE COVER SUBSCRIPTION
// ==========================================

model Subscription {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  customerId String   @unique @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])

  // Stripe billing
  stripeSubscriptionId String @unique
  stripeCustomerId     String
  stripePriceId        String // Stripe Price ID for the plan

  // Plan details
  plan   String @default("cover_monthly") // "cover_monthly" | "cover_annual"
  status String @default("active") // active | past_due | canceled | trialing | paused

  // Perks
  assessmentFeeDiscount Float   @default(1.0) // Multiplier on assessment fee (0.5 = 50% off)
  priorityDispatch      Boolean @default(true)
  freeCallouts          Int     @default(0) // Remaining free callouts this period
  freeCalloutsTotal     Int     @default(1) // Free callouts per billing period

  // Billing period
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?

  // Trial
  trialStart DateTime?
  trialEnd   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([currentPeriodEnd])
}

// =========================================================================
// Google Ads Copilot — Campaign Suggestion Queue
// =========================================================================
// Every insight the AI generates becomes a suggestion card here. No Google
// Ads mutations fire without a human APPROVE action on this record.
// The ads-specialist / opportunity-scout agents write rows; the admin
// dashboard reads and acts on them.
model CampaignSuggestion {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // What type of action is being suggested.
  // "ADD_NEGATIVE_KEYWORD" | "ADD_KEYWORD" | "REMOVE_KEYWORD"
  // "INCREASE_BUDGET"      | "DECREASE_BUDGET"
  // "LOWER_BID"            | "RAISE_BID"
  // "PAUSE_CANDIDATE"      | "SCALE_WINNER"
  // "NEW_DRAFT_CITY"       ← cheap-city discovery suggestions
  type String

  // Which Google Ads campaign draft this concerns (nullable for NEW_DRAFT_CITY).
  draftId          String? @db.ObjectId
  draft            GoogleAdsCampaignDraft? @relation(fields: [draftId], references: [id])
  googleCampaignId String?
  campaignName     String?

  // Raw evidence shown to the admin in plain English.
  // e.g. { keyword: "car locksmith", spend: 4.20, conversions: 0, clicks: 23, days: 7 }
  evidence Json

  // What the AI proposes to change.
  // e.g. { negativeKeyword: "car locksmith" } or { newDailyBudget: 9.00 }
  suggestedValue Json

  // What it currently is (for budget/bid suggestions).
  currentValue Json?

  // Plain-English reasoning shown to the admin.
  reasoning String

  // AI self-assessed confidence 0–1. Low-confidence suggestions are surfaced
  // less prominently in the UI and filtered by stricter thresholds.
  confidence Float @default(0.5)

  // Status lifecycle.
  // PENDING → APPROVED → APPLIED (mutation fired successfully)
  //         → REJECTED
  //         → EXPIRED  (not actioned within 7 days)
  status String @default("PENDING")

  // Human decision fields.
  approvedBy     String?
  approvedAt     DateTime?
  rejectedBy     String?
  rejectedAt     DateTime?
  // "too_early" | "disagree_with_data" | "manual_override_planned"
  // "wrong_context" | "already_handled" | "other"
  rejectedReason String?

  // Execution result.
  appliedAt  DateTime?
  applyError String?

  // Which agent produced this suggestion.
  agentId String? @db.ObjectId

  createdAt DateTime @default(now())
  // Suggestions auto-expire after 7 days if not actioned.
  expiresAt DateTime

  @@index([status, createdAt])
  @@index([draftId])
  @@index([googleCampaignId])
  @@index([type, status])
}

/// Per-call attribution row. Logged the instant a visitor clicks the
/// Call CTA on the website, BEFORE tel: opens. Captures gclid + UTMs
/// so we can match the eventual inbound Retell call back to the click
/// that drove it — closing the loop on the "one shared website phone"
/// approach without needing per-campaign DIDs.
///
/// Match flow:
///   1. Visitor clicks Call → POST /api/marketing/call-intent → row created
///   2. tel: opens, user is connected via Zadarma → Retell
///   3. Retell webhook (or call-end event) hits us with the inbound number
///      + start time. We find the most recent unmatched CallIntent for
///      that visitor (or, when visitorId is unknown, the freshest intent
///      within the last 5 minutes) and stamp the retellCallId here.
///   4. When the resulting Job completes paid, the Stripe webhook reads
///      the CallIntent.gclid via Job.callIntentId and fires the Google Ads
///      offline-conversion upload.
model CallIntent {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  visitorId String?
  sessionId String? @db.ObjectId

  // ── Attribution captured at click time ──────────────────────────────
  gclid       String?
  fbclid      String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  landingPage String?
  pagePath    String? // page the Call button was clicked from

  // ── Click context ───────────────────────────────────────────────────
  source   String  // "website_call_button" | "ad_click_to_call" | "modal_cta"
  buttonId String? // optional CTA identifier (e.g. "hero", "sticky-footer")
  userAgent String?

  // ── Retell match ────────────────────────────────────────────────────
  matched      Boolean   @default(false)
  matchedAt    DateTime?
  retellCallId String? // Retell's call ID once matched
  // The phone number caller-ID we observed (when available). Stored for
  // audit; never used as a join key because UK callers frequently withhold
  // CLI and many will hit us from numbers we've never seen before.
  callerIdE164 String?

  // ── Downstream linkage ──────────────────────────────────────────────
  jobId String? @db.ObjectId
  // Conversion upload tracking — mirrors the per-Job fields on Job.
  conversionUploadedAt   DateTime?
  conversionUploadStatus String? // "uploaded" | "skipped:no_gclid" | "skipped:no_job" | "error"
  conversionUploadError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visitorId])
  @@index([retellCallId])
  @@index([matched, createdAt])
  @@index([createdAt])
}

/// Per-postcode-district landing page. One row per UK outcode where we
/// have at least one active LocksmithCoverage entry. Content is
/// AI-generated from STRUCTURED FACTS (real engineer name, coverage
/// radius, anchor town, nearby outcodes) so each page reads as a real
/// local locksmith page — not a programmatic doorway.
///
/// Generation lifecycle:
///   1. orchestrator creates a campaign draft for keyword containing district D
///   2. ensureDistrictLandingPage(D) is called BEFORE the draft is written
///   3. if no row exists, the generator pulls facts (locksmith data,
///      postcodes.io enrichment) and calls Ollama (OpenAI fallback) to
///      produce the prose blocks
///   4. row persisted; draft's finalUrl = /locksmith/{district}
///   5. /locksmith/[district] route reads this row on render
///
/// Regeneration:
///   • triggered when generatedAt is older than REGENERATE_AFTER_DAYS
///   • or when contentSource = "needs_refresh" (manual flag)
///   • manual edits via admin set contentSource = "manual_override"
///     and the regenerator never overwrites them.
model DistrictLandingPage {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  /// UK outcode, uppercase. E.g. "RG1", "SW1A", "M1".
  district  String @unique
  /// URL slug — lowercase district. Stored separately so we can change
  /// the URL convention later without losing the district key.
  slug      String @unique

  // ── Resolved local facts (the LLM's grounding data) ─────────────────
  /// Anchor town for the outcode (Reading, Manchester, etc.)
  anchorTown      String?
  /// County or region (Berkshire, Greater Manchester, etc.)
  region          String?
  /// Outcode centroid for distance computation.
  lat             Float?
  lng             Float?
  /// Outcodes adjacent to this one (within ~10mi). E.g. for RG1: ["RG2","RG4","RG6","RG30"]
  nearbyOutcodes  String[] @default([])
  /// Locksmith IDs covering this district (mirrors LocksmithCoverage).
  locksmithIds    String[] @default([])
  /// The primary engineer to highlight in the hero copy.
  featuredLocksmithId String?
  /// Their displayed first name in the copy (cached so we don't re-join).
  featuredEngineerName String?

  // ── Generated content blocks ────────────────────────────────────────
  /// Hero headline — 6-12 words, district-specific. NOT a template fill.
  heroHeadline       String?
  /// One short sentence supporting the hero.
  heroSubcopy        String?
  /// Opening paragraph (3-5 sentences) introducing the district.
  introParagraph     String?
  /// Paragraph about WHO covers the district — names the engineer.
  coverageNarrative  String?
  /// Trust paragraph — fixed price, MLA, DBS, no-callout-fee positioning.
  whyChooseUs        String?
  /// District-specific FAQs (4-6 entries). [{question, answer}]
  faqs               Json     @default("[]")
  /// Short bullet points for the trust strip ("Within 8mi of all RG1 postcodes").
  localTrustAnchors  String[] @default([])

  // ── Provenance + lifecycle ──────────────────────────────────────────
  /// "ai_generated" | "manual_override" | "needs_refresh"
  contentSource  String   @default("ai_generated")
  /// Which model produced the content. e.g. "ollama:llama3.1:8b" / "openai:gpt-4o-mini"
  llmModel       String?
  /// Free-text notes from an admin (only used when contentSource = manual_override).
  adminNotes     String?
  /// True = visible at /locksmith/{district}. False = hidden (e.g. coverage paused).
  isPublished    Boolean  @default(true)

  generatedAt  DateTime?
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isPublished])
  @@index([contentSource])
  @@index([generatedAt])
}
