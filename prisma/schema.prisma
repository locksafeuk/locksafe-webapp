// Descending-clock job auction for high-supply areas
model JobAuction {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  jobId String @unique @db.ObjectId
  job   Job    @relation(fields: [jobId], references: [id])

  state       String   @default("RUNNING") // RUNNING | ACCEPTED | EXPIRED | ADMIN_ASSIGNED
  currentStep Int      @default(0) // 0=40% | 1=30% | 2=25%
  currentRate Float    @default(0.40) // Commission rate currently on offer
