// ============================================
// AI AGENT OPERATING SYSTEM MODELS
// ============================================

// Agent definition - autonomous AI workers
model Agent {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String   @unique                    // "ceo", "cto", "cmo", "coo"
  displayName     String                              // "CEO Agent", "COO Agent"
  role            String                              // Role description

  // Hierarchy
  parentAgentId   String?  @db.ObjectId

  status          String   @default("active")         // active, paused, terminated
  skillsPath      String                              // Path to SKILL.md file

  // Budget Control
  monthlyBudgetUsd   Float    @default(50)            // Monthly token budget ($)
  budgetUsedUsd      Float    @default(0)             // Current month usage
  budgetResetAt      DateTime @default(now())         // When budget resets

  // Heartbeat Configuration
  heartbeatEnabled   Boolean  @default(true)
  heartbeatCronExpr  String   @default("*/30 * * * *") // Cron expression
  lastHeartbeat      DateTime?
  nextHeartbeat      DateTime?

  // Permissions
  permissions        String[] @default([])            // Tool access list
  governanceLevel    String   @default("autonomous")  // autonomous, supervised, approval_required

  // Stats
  totalTasksCompleted Int     @default(0)
  totalExecutions     Int     @default(0)
  successRate         Float   @default(100)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tasks           AgentTask[]
  executions      AgentExecution[]
  memories        AgentMemory[]
}

// Task assigned to an agent
model AgentTask {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  agentId         String   @db.ObjectId
  agent           Agent    @relation(fields: [agentId], references: [id])

  parentTaskId    String?  @db.ObjectId               // Parent task (delegation)

  title           String
  description     String
  priority        Int      @default(5)                // 1-10, 10 = highest
  status          String   @default("pending")        // pending, in_progress, completed, failed, blocked

  // Goal Alignment
  companyGoalId   String?  @db.ObjectId
  projectContext  String?                             // Context about what this achieves

  // Delegation
  delegatedFrom   String?                             // Agent that delegated this
  delegatedTo     String?                             // Subagent to execute

  // Execution
  assignedAt      DateTime @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  deadline        DateTime?

  // Results
  result          String?                             // JSON result
  resultSummary   String?                             // Human-readable summary
  error           String?

  // Cost tracking
  tokensUsed      Int      @default(0)
  costUsd         Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Agent execution log (immutable audit trail)
model AgentExecution {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  agentId         String   @db.ObjectId
  agent           Agent    @relation(fields: [agentId], references: [id])

  taskId          String?  @db.ObjectId
  traceId         String                              // Group related executions

  // Execution details
  actionType      String                              // tool_call, decision, delegation, heartbeat
  actionName      String                              // Tool name or action description
  input           String                              // JSON input
  output          String?                             // JSON output
  status          String   @default("success")        // success, failed, blocked, pending_approval

  // Cost tracking
  tokensUsed      Int      @default(0)
  costUsd         Float    @default(0)
  model           String?                             // AI model used (gpt-4, etc)

  // Timing
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  durationMs      Int?

  // Approval (if needed)
  requiresApproval Boolean @default(false)
  approvedBy       String?                            // Admin who approved
  approvedAt       DateTime?

  createdAt       DateTime @default(now())
}

// Agent memory (short + long term)
model AgentMemory {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  agentId         String   @db.ObjectId
  agent           Agent    @relation(fields: [agentId], references: [id])

  type            String   @default("short")          // short, long, system
  category        String                              // decisions, campaigns, patterns, bugs, etc

  content         String                              // The memory content
  metadata        String?                             // JSON metadata

  // Relevance
  importance      Float    @default(0.5)              // 0-1 importance score
  lastAccessedAt  DateTime @default(now())
  accessCount     Int      @default(1)

  // Expiry
  expiresAt       DateTime?                           // Null = permanent

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Company goals (for goal alignment)
model CompanyGoal {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  title           String
  description     String
  type            String   @default("strategic")      // strategic, quarterly, project

  status          String   @default("active")         // active, completed, paused
  priority        Int      @default(5)                // 1-10

  // Metrics
  targetMetric    String?                             // What we're measuring
  targetValue     Float?                              // Target value
  currentValue    Float?                              // Current progress
  progress        Float    @default(0)                // 0-100%

  // Ownership
  ownerAgentId    String?  @db.ObjectId               // Primary agent responsible

  deadline        DateTime?
  completedAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==========================================
// VOICE AI RECEPTIONIST SYSTEM (Retell AI)
// ==========================================

// Voice call records from Retell AI
model VoiceCall {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  // Retell AI identifiers
  retellCallId    String   @unique  // Retell's call_id
  agentId         String?            // Retell agent ID used

  // Caller info
  callerPhone     String?            // Caller's phone number
  callerName      String?            // Extracted from conversation
  callerPostcode  String?            // Extracted postcode

  // Call metadata
  callType        String   @default("inbound")  // inbound, outbound, web
  callStatus      String   @default("in_progress") // in_progress, completed, failed, transferred
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  durationSeconds Int?

  // Classification
  callCategory    String?  // emergency, appointment, inquiry, complaint, spam
  urgencyLevel    String?  // critical, high, medium, low
  problemType     String?  // lockout, broken_lock, security_upgrade, rekeying, consultation
  propertyType    String?  // residential, commercial, automotive

  // Outcome
  outcome         String?  // job_created, appointment_booked, info_provided, escalated, abandoned
  outcomeDetails  Json?    // Details about the outcome

  // Linked entities
  jobId           String?  @db.ObjectId  // Created job (if any)
  customerId      String?  @db.ObjectId  // Linked customer (if identified)
  locksmithId     String?  @db.ObjectId  // Dispatched locksmith (if any)
  bookingDate     DateTime?              // For appointment bookings

  // Sentiment & quality
  sentimentScore  Float?   // -1 to 1 (negative to positive)
  sentimentLabel  String?  // positive, neutral, negative
  customerSatisfaction Int? // 1-5 post-call survey

  // Transcript
  transcript      Json?    // Full transcript array [{role, content, timestamp}]
  summary         String?  // AI-generated call summary

  // Recording
  recordingUrl    String?
  recordingDuration Int?

  // Call analysis from Retell
  callAnalysis    Json?    // Full analysis object from Retell

  // Revenue attribution
  estimatedRevenue Float?  // Estimated revenue from this call
  actualRevenue    Float?  // Actual revenue (after job completion)

  // Deduplication
  dedupeKey       String?  @unique  // For webhook deduplication

  // Human escalation
  wasEscalated    Boolean  @default(false)
  escalationReason String?
  escalatedTo     String?  // Phone number or name of human agent

  // Flags
  flaggedForReview Boolean @default(false)
  reviewNotes     String?
  isTestCall      Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([callerPhone])
  @@index([callCategory])
  @@index([callStatus])
  @@index([startedAt])
  @@index([outcome])
}

// Voice agent configuration and prompts
model VoiceAgentConfig {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  name            String   @unique  // Config name/version
  isActive        Boolean  @default(false)

  // Retell AI config
  retellAgentId   String?  // Retell agent ID
  retellLlmId     String?  // Retell LLM ID

  // Voice settings
  voiceId         String?  // TTS voice ID
  language        String   @default("en-GB")
  speakingRate    Float    @default(1.0)

  // Prompts
  systemPrompt    String   // Main agent prompt
  greetingMessage String?  // Initial greeting
  fallbackMessage String?  // When agent can't understand

  // Behavior
  maxCallDuration Int      @default(600) // Max seconds (10 min default)
  silenceTimeout  Int      @default(10)  // Seconds of silence before prompting
  enableRecording Boolean  @default(true)

  // Business hours
  businessHoursStart String @default("00:00") // 24/7 by default
  businessHoursEnd   String @default("23:59")
  afterHoursMessage  String?

  // Feature toggles
  enableDispatch     Boolean @default(true)
  enableBooking      Boolean @default(true)
  enableFAQ          Boolean @default(true)
  enableEscalation   Boolean @default(true)

  // Status
  isPaused        Boolean  @default(false)
  pauseReason     String?

  // Blocked numbers
  blockedNumbers  String[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Daily/hourly call analytics snapshots
model CallAnalyticsSnapshot {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  // Time period
  periodType      String   // hourly, daily, weekly, monthly
  periodStart     DateTime
  periodEnd       DateTime

  // Volume metrics
  totalCalls      Int      @default(0)
  emergencyCalls  Int      @default(0)
  appointmentCalls Int     @default(0)
  inquiryCalls    Int      @default(0)
  spamCalls       Int      @default(0)

  // Duration metrics
  avgDurationSeconds Float @default(0)
  maxDurationSeconds Int   @default(0)
  minDurationSeconds Int   @default(0)

  // Outcome metrics
  jobsCreated     Int      @default(0)
  appointmentsBooked Int   @default(0)
  escalations     Int      @default(0)
  abandonedCalls  Int      @default(0)

  // Conversion metrics
  callToJobRate   Float    @default(0)  // Percentage
  callToBookingRate Float  @default(0)

  // Sentiment
  avgSentimentScore Float  @default(0)
  negativeSentimentCount Int @default(0)

  // Revenue
  estimatedRevenue Float   @default(0)
  actualRevenue    Float   @default(0)

  // Performance
  avgResponseTime  Float   @default(0)  // Seconds to first dispatch
  avgTimeToDispatch Float  @default(0)

  createdAt       DateTime @default(now())

  @@unique([periodType, periodStart])
  @@index([periodType])
  @@index([periodStart])
}

// Agent governance - pending approvals
model AgentApproval {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  agentId         String   @db.ObjectId
  executionId     String   @db.ObjectId

  actionType      String                              // What action needs approval
  actionDetails   String                              // JSON description
  reason          String                              // Why approval is needed

  // Optional structured target reference for fast lookup by approval consumers
  // (e.g. ad publish gate). actionDetails JSON remains the canonical source.
  targetType      String?                             // e.g. "google_ads_draft", "ad_campaign"
  targetId        String?                             // FK string to the target row

  status          String   @default("pending")        // pending, approved, rejected

  // Resolution
  resolvedBy      String?                             // Admin ID
  resolvedAt      DateTime?
  resolution      String?                             // Approval notes

  // Notification
  notifiedVia     String[] @default([])               // telegram, email, dashboard

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([targetType, targetId, status])
  @@index([status, createdAt])
}

// Token Blacklist for logout/revoked JWT tokens
model TokenBlacklist {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique // The JWT token (hashed for security)
  userId    String   // ID of the user who logged out
  userType  String   // "admin", "locksmith", or "customer"
  expiresAt DateTime // When the token would have expired naturally
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ==========================================
// PUSH NOTIFICATION SUBSCRIPTIONS
// ==========================================

// Push subscription storage for guest users
// Links to user when they register/login
model PushSubscription {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  playerId     String   @unique  // OneSignal player ID (UUID)
  userType     String   @default("guest") // guest, customer, locksmith

  // Linked user (populated when guest converts)
  customerId   String?  @db.ObjectId
  locksmithId  String?  @db.ObjectId

  // Subscription metadata
  subscribedAt DateTime @default(now())
  linkedAt     DateTime? // When subscription was linked to a user

  // Device info (for debugging)
  deviceType   String?  // mobile, desktop, tablet
  browser      String?  // chrome, safari, firefox, edge
  os           String?  // ios, android, windows, macos

  // Status
  isActive     Boolean  @default(true)
  unsubscribedAt DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([customerId])
  @@index([locksmithId])
  @@index([isActive])
}

// ============================================================================
// META (FACEBOOK) CATALOG — service-intent catalog for dynamic ads.
// Drives /api/meta/catalog-feed and the admin sync to Meta Graph API.
// ============================================================================

// Per-slug overrides for the static service catalog. The default copy lives in
// `src/lib/services-catalog.ts`; this model only stores admin overrides such
// as a custom-uploaded image and per-item Meta sync state.
model ServiceCatalogItem {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  slug                String    @unique // matches ServiceSlug in code
  imageUrl            String?   // custom uploaded image (Vercel Blob URL); overrides dynamic OG
  customTitle         String?
  customDescription   String?
  // Meta Catalog sync state
  metaProductId       String?   // returned product id once synced
  metaRetailerId      String?   // retailer_id we sent (== slug)
  lastSyncedAt        DateTime?
  lastSyncStatus      String?   // "success" | "error"
  lastSyncMessage     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// Singleton-ish config for the connected Meta Commerce catalog. The first row
// with `isActive = true` is treated as the active configuration.
model MetaCatalogConfig {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  catalogId           String    // FB catalog id (numeric string)
  catalogName         String?
  feedId              String?   // optional scheduled-feed id pointing at /api/meta/catalog-feed
  feedUrl             String?
  isActive            Boolean   @default(true)
  lastFullSyncAt      DateTime?
  lastFullSyncStatus  String?   // "success" | "error" | "partial"
  lastFullSyncMessage String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// Cache mapping from a set of service catalog slugs to a Meta Product Set id.
// Reused so we don't re-create the same product_set on every campaign launch.
model ServiceCatalogProductSet {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  catalogId       String   // FB catalog id this product_set belongs to
  productSetId    String   @unique // FB product_set id
  name            String
  /// Sorted, comma-joined slug list — used as a stable lookup key.
  slugsKey        String   @unique
  slugs           String[] // raw slug array, mirrors slugsKey
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([catalogId])
}

// Per-action audit row written by the Meta optimiser (and other agent loops).
// Keeps a forensic trail of WHY an automated action was taken — including the
// policy snapshot at decision time and whether the action was actually
// executed (live) or merely proposed (dryRun).
model AgentDecision {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  agent           String   // "cmo" | "meta-optimiser" | "ads-specialist" | etc.
  platform        String   // "meta" | "google"
  action          String   // "pause_ad" | "scale_adset" | "rotate_creative" | "exclude_converters"
  /// Free-form context — adId/adSetId/campaignId, metric snapshot, reasoning.
  payload         Json
  /// Frozen `MarketingPolicy` view used for the decision. Lets us re-evaluate
  /// historical actions even after the policy is changed.
  policySnapshot  Json
  dryRun          Boolean  @default(true)
  /// Outcome of execution — "ok", "blocked_by_policy", "blocked_by_spend", "error", or null when dryRun.
  outcome         String?
  outcomeMessage  String?
  executedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([agent, createdAt])
  @@index([platform, action, createdAt])
}

