// Saved Audiences
model AdAudience {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Meta IDs
  metaAudienceId String?       @unique // Custom/Lookalike audience ID
  accountId      String        @db.ObjectId
  account        MetaAdAccount @relation(fields: [accountId], references: [id])

  // Audience info
  name        String
  description String?
  type        AudienceType @default(SAVED)

