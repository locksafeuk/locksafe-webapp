// AI Content Generation Log
model AIGeneration {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Request
  type    String // copy, audience, analysis, optimization
  prompt  String
  context Json? // Additional context provided

  // Response
  output     Json // Generated content
  tokensUsed Int    @default(0)
  model      String @default("gpt-4")

  // Usage tracking
  usedInCampaign String? @db.ObjectId
  usedInAd       String? @db.ObjectId
  wasAccepted    Boolean @default(false)

  createdAt DateTime @default(now())
}

// Ad Performance Snapshots (for historical tracking)
model AdPerformanceSnapshot {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Platform discriminator. "meta" rows reference adId/adSetId/campaignId
  // (ObjectIds into our DB). "google" rows reference googleCampaignId
  // (string ID from Google Ads API) since we don't mirror Google campaigns
  // into AdCampaign in Phase 1.
  platform String @default("meta")

  // Reference
  adId       String? @db.ObjectId
  adSetId    String? @db.ObjectId
  campaignId String? @db.ObjectId

  // Google-specific identifiers (used when platform = "google")
  googleAccountId    String? @db.ObjectId
  googleCampaignId   String? // Google Ads numeric campaign ID
  googleCampaignName String? // Denormalised for reporting without an extra fetch

  // Date
  date DateTime @db.Date

  // Metrics
  spend       Float
  impressions Int
  clicks      Int
  conversions Int
  revenue     Float
  ctr         Float
  cpc         Float
  cpm         Float
  roas        Float
  frequency   Float? // Average times shown per person

  // City isolation — Google geo target constant for the campaign's primary geo.
  // Populated during sync from GoogleAdsCampaignDraft.geoTargets[0].
  // Allows city-scoped queries without joining back to the draft table.
  geoId String? // e.g. "1006886" (Birmingham), "1006886" (Manchester), etc.

  createdAt DateTime @default(now())

  @@index([adId, date])
  @@index([campaignId, date])
  @@index([googleCampaignId, date])
  @@index([platform, date])
  @@index([geoId, platform, date])
}

// UTM Templates
model UTMTemplate {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name        String
  description String?

  // UTM parameters
  source   String
  medium   String
  campaign String?
  content  String?
  term     String?

  // Usage
  useCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Enums
enum AdObjective {
  AWARENESS // Brand awareness
  TRAFFIC // Link clicks
  ENGAGEMENT // Post engagement
  LEADS // Lead generation
  SALES // Conversions/purchases
  APP_INSTALLS // App installs
}

enum AdStatus {
  DRAFT // Not yet published
  PENDING_REVIEW // Submitted to Meta, pending review
  ACTIVE // Running
  PAUSED // Manually paused
  REJECTED // Rejected by Meta
  COMPLETED // Budget exhausted or end date reached
  ARCHIVED // Archived
}

enum CreativeType {
  IMAGE // Single image
  VIDEO // Video
  CAROUSEL // Multiple images/videos
  COLLECTION // Collection ad
}

enum AudienceType {
  SAVED // Saved audience (targeting spec)
  CUSTOM // Custom audience (website visitors, customer list)
  LOOKALIKE // Lookalike audience
}

// ==========================================
// ORGANIC SOCIAL MEDIA POSTING SYSTEM
