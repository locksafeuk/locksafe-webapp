// Phase 3 — Marketing policy / spend guard.
// One row per platform ("meta" | "google" | "global"). Consulted by every
// auto-publish and auto-optimisation path. The "global" row is a master kill
// switch that overrides per-platform settings.
model MarketingPolicy {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  platform String @unique // "meta" | "google" | "global"

  // Master kill switch — when false, every auto-action for this platform
  // is blocked, including auto-approve and optimiseGoogleCampaigns.
  // Manual admin actions through the UI are unaffected.
  autonomyEnabled Boolean @default(false)

  // Copilot-mode hard guard. When false (default), NO automatic mutations
  // are sent to Google Ads / Meta — every action proposed by an agent is
  // written to the CampaignSuggestion queue for human approve/reject.
  // This is a defence-in-depth flag on top of autonomyEnabled: even if
  // autonomyEnabled is accidentally flipped on, this must also be true
  // for any auto-mutation to fire.
  allowAutomaticMutations Boolean @default(false)

  // Copilot mode (always-on by default): generate suggestions even when
  // autonomyEnabled is false, so humans get a queue to review.
  copilotEnabled Boolean @default(true)

  // Hard caps (GBP). 0 = "not enforced" (use parent global row).
  maxDailySpend          Float @default(15) // total per platform per day
  maxMonthlySpend        Float @default(300) // total per platform per calendar month
  maxCampaignDailyBudget Float @default(20) // largest single-campaign budget the agent may set
  minCampaignDailyBudget Float @default(2) // smallest budget below which the agent should pause instead

  // Auto-approval thresholds. If the agent files an approval whose
  // dailyBudget <= autoApproveMaxBudget AND the platform's autonomyEnabled
  // AND the past 7d spend < maxWeeklyAutoApproveSpend, the system resolves
  // it without admin input. Anything above bumps to manual review.
  autoApproveMaxBudget      Float @default(10) // GBP/day
  maxWeeklyAutoApproveSpend Float @default(50) // GBP rolling 7d agent-initiated
  autoApproveMinConfidence  Float @default(0.85) // AI confidence threshold for auto-approval (0–1)

  // Optimisation guards
  pauseRoasThreshold     Float @default(0.5) // pause campaigns under this ROAS after grace
  pauseGraceDays         Int   @default(3) // require N days under threshold before pausing
  minImpressionsForPause Int   @default(500) // ignore tiny-volume campaigns

  // Notification settings
  notifyOnAutoAction Boolean @default(true) // Telegram/email when agent acts

  // LLM emergency fallback policy (local-first by default).
  // When disabled, agent/model calls must stay on Ollama/Hermes and cannot
  // fail over to OpenAI.
  openAiFallbackEnabled     Boolean? @default(false)
  openAiFallbackMinSeverity String?  @default("high") // low | medium | high | critical

  // Operational policy (runtime controls for orchestrator).
  // guardianModeEnabled: when true, only guardian agents (coo, cto) run; other
  //   agents are skipped silently to cut Telegram/token noise during incidents.
  // alertSensitivity: "all" | "workflow" | "critical" — gates Telegram alerts
  //   from non-workflow agents.
  // nonWorkflowHeartbeatMultiplier: integer >=1 that multiplies the cadence of
  //   non-guardian agents (e.g. 2 = run half as often). Applied at dispatch time.
  guardianModeEnabled            Boolean? @default(false)
  alertSensitivity               String?  @default("workflow") // all | workflow | critical
  nonWorkflowHeartbeatMultiplier Int?     @default(1)

  // Control-plane enforcement toggles (global row). Null = fall back to the
  // CONTROL_PLANE_*_ENFORCE env var. cpKillSwitch forces everything to shadow.
  cpAlertEnforce       Boolean?
  cpDispatchEnforce    Boolean?
  cpApprovalEnforce    Boolean?
  cpSelfImproveEnforce Boolean?
  cpKillSwitch         Boolean? @default(false)

  // Audit
  updatedBy String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Phase 3 — daily spend ledger keyed by (platform, date).
// Lightweight rollup written by the spend-guard whenever it consults the
// snapshot tables, so subsequent guard checks are O(1). Idempotent: re-write
// safely; the value is the canonical aggregate, not a delta.
model DailySpendLedger {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  platform   String // "meta" | "google"
  date       DateTime // UTC midnight of the day
  spend      Float    @default(0)
  agentSpend Float    @default(0) // subset spent on agent-initiated campaigns
  source     String   @default("snapshot") // "snapshot" | "manual"
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([platform, date])
  @@index([date])
}

// Ad Campaign
model AdCampaign {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Meta IDs
  // NOTE: not @unique — MongoDB's unique index treats multiple null values as
  // duplicates, which blocks creating a 2nd draft (P2002). Meta's IDs are
  // globally unique by construction, so we rely on the API for uniqueness
  // and use a non-unique index for lookups.
  metaCampaignId String? // ID from Meta after creation
  accountId      String        @db.ObjectId
  account        MetaAdAccount @relation(fields: [accountId], references: [id])

  // Campaign settings
  name      String
  objective AdObjective
  status    AdStatus    @default(DRAFT)

  // Budget
  dailyBudget    Float? // Daily budget in currency
  lifetimeBudget Float? // Lifetime budget
  bidStrategy    String @default("LOWEST_COST") // LOWEST_COST, COST_CAP, BID_CAP

  // Schedule
  startDate DateTime?
  endDate   DateTime?

  // Performance tracking
  totalSpend       Float @default(0)
  totalImpressions Int   @default(0)
  totalClicks      Int   @default(0)
  totalConversions Int   @default(0)
  totalRevenue     Float @default(0)

  // AI metadata
  aiGenerated Boolean @default(false)
  aiPrompt    String? // Original prompt used

  // Relations
  adSets AdSet[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSyncAt DateTime?

  @@index([accountId])
  @@index([status])
  @@index([metaCampaignId])
}

// Ad Set (targeting and budget at ad set level)
model AdSet {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Meta IDs (see AdCampaign.metaCampaignId for why this isn't @unique)
  metaAdSetId String?
  campaignId  String     @db.ObjectId
  campaign    AdCampaign @relation(fields: [campaignId], references: [id])

  // Ad set settings
  name   String
  status AdStatus @default(DRAFT)

  // Budget (can override campaign)
  dailyBudget    Float?
  lifetimeBudget Float?

  // Schedule
  startDate DateTime?
  endDate   DateTime?

  // Optimization
  optimizationGoal String @default("LEAD") // LEAD, CONVERSIONS, LINK_CLICKS, etc.
  billingEvent     String @default("IMPRESSIONS") // IMPRESSIONS, LINK_CLICKS

  // Targeting
  targeting Json // Full targeting spec (locations, demographics, interests)

  // Catalog binding (Advantage+ Catalog Ads). When set, the adset renders
  // dynamic creatives keyed off the product set instead of static images.
  productSetId   String? // Meta product_set id
  serviceSlugs   String[] // catalog item slugs included (== retailer_id list)
  isCatalogAdset Boolean  @default(false)
  /// "prospecting" | "retargeting" — drives audience composition.
  catalogMode    String?

  // Placements
  placements String[] // FEED, STORIES, REELS, etc. (empty = automatic)

  // Performance
  spend       Float @default(0)
  impressions Int   @default(0)
  clicks      Int   @default(0)
  conversions Int   @default(0)
  ctr         Float @default(0)
  cpc         Float @default(0)
  cpm         Float @default(0)

  // Relations
  ads        Ad[]
  audienceId String? @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@index([metaAdSetId])
}

// Individual Ad
model Ad {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Meta IDs (see AdCampaign.metaCampaignId for why this isn't @unique)
  metaAdId String?
  adSetId  String  @db.ObjectId
  adSet    AdSet   @relation(fields: [adSetId], references: [id])

  // Ad settings
  name   String
  status AdStatus @default(DRAFT)

  // Creative
  creativeId String     @db.ObjectId
  creative   AdCreative @relation(fields: [creativeId], references: [id])

  // Tracking (auto-configured)
  trackingUrl    String? // Final URL with UTM + fbclid
  utmSource      String  @default("facebook")
  utmMedium      String  @default("paid")
  utmCampaign    String? // Auto-set from campaign name
  utmContent     String? // Auto-set from ad name
  pixelEventType String? // Lead, Purchase, etc.

  // Performance
  spend       Float @default(0)
  impressions Int   @default(0)
  clicks      Int   @default(0)
  conversions Int   @default(0)
  revenue     Float @default(0)
  ctr         Float @default(0)
  cpc         Float @default(0)
  roas        Float @default(0)

  // AI metadata
  aiGenerated Boolean @default(false)
  aiVariation String? // "emotional", "urgency", "social_proof", etc.

  // Review status
  metaReviewStatus   String? // PENDING, APPROVED, REJECTED
  metaReviewFeedback String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSyncAt DateTime?

  @@index([adSetId])
  @@index([status])
  @@index([metaAdId])
}

// Ad Creative (reusable across ads)
model AdCreative {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Meta IDs (see AdCampaign.metaCampaignId for why this isn't @unique)
  metaCreativeId String?

  // Creative type
  type CreativeType @default(IMAGE)

  // Content
  primaryText  String // Main ad copy
  headline     String // Headline
  description  String? // Link description
  callToAction String  @default("LEARN_MORE") // CTA button type

  // Media
  imageUrl     String? // Image URL
  imageHash    String? // Meta image hash after upload
  videoUrl     String?
  videoId      String? // Meta video ID
  thumbnailUrl String?

  // Link
  destinationUrl String // Landing page URL (without UTM)
  displayUrl     String? // Display URL shown in ad

  // AI metadata
  aiGenerated    Boolean @default(false)
  aiPrompt       String?
  emotionalAngle String? // emotional, urgency, social_proof, benefit

