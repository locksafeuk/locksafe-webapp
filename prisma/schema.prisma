// ==========================================
// MARKETING FUNNEL & USER TRACKING SYSTEM
// ==========================================

// User session tracking for behavior analysis
model UserSession {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  visitorId  String // Fingerprint/cookie ID
  customerId String? @db.ObjectId

  // Session data
  startedAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  deviceType   String // mobile, tablet, desktop
  browser      String
  referrer     String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  // Added for the Conversions-API attribution path. Without gclid we
  // cannot upload completed-job conversions back to Google Ads, which
  // means Google's auction never learns to bid on real outcomes — and
  // we get ripped off by vanity-click optimisation.
  utmContent   String?
  utmTerm      String?
  gclid        String?
  fbclid       String?
  landingPage  String

  // Tracking
  pageViews   PageView[]
  events      UserEvent[]
  funnelStage String      @default("visitor") // visitor, lead, prospect, customer, advocate
  segment     String[] // emergency, price_shopper, researcher, etc.

  // Scoring
  engagementScore Int @default(0)
  intentScore     Int @default(0)

  // Modal history
  modalsShown     String[]
  modalsDismissed String[]
  modalsConverted String[]

  @@index([visitorId])
  @@index([customerId])
}

// Page view tracking
model PageView {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  sessionId String      @db.ObjectId
  session   UserSession @relation(fields: [sessionId], references: [id])

  path        String
  title       String?
  timeOnPage  Int? // seconds
  scrollDepth Int     @default(0) // percentage

  createdAt DateTime @default(now())

  @@index([sessionId])
}

// User event tracking (clicks, interactions, etc.)
model UserEvent {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  sessionId String      @db.ObjectId
  session   UserSession @relation(fields: [sessionId], references: [id])

  type    String // click, form_start, form_abandon, scroll, hover, etc.
  element String? // Button ID, form name, etc.
  data    Json?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([type])
}

// Funnel triggers for modals and popups
model FunnelTrigger {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String  @unique
  description String?

  // Trigger conditions
  conditions Json // Complex conditions object

  // Action
  modalType   String // survey, offer, lead_magnet, exit_intent, etc.
  modalConfig Json // Modal content and styling

  // Targeting
  segments     String[] // Which segments to show
  funnelStages String[] // Which funnel stages

  // Limits
  priority      Int     @default(0)
  showOnce      Boolean @default(true)
  cooldownHours Int     @default(24)
  maxShows      Int     @default(1)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Modal interaction tracking
model ModalInteraction {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  sessionId  String
  visitorId  String
  customerId String?

  modalType String
  triggerId String?

  action String // shown, dismissed, converted, completed
  data   Json? // Survey responses, form data, etc.

  createdAt DateTime @default(now())

  @@index([visitorId])
  @@index([modalType])
}

// Lead magnet signups
model LeadMagnet {
  id    String  @id @default(auto()) @map("_id") @db.ObjectId
  email String
  name  String?
  phone String?

  source  String // Which lead magnet/popup
  segment String[]

  downloaded String[] // Which assets they downloaded

  emailsSent    String[] // Which emails they've received
  emailsOpened  String[]
  emailsClicked String[]

  convertedToCustomer Boolean @default(false)
  customerId          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// ==========================================
// AI-POWERED AD CREATION SYSTEM
// ==========================================

// Meta Business account connection
model MetaAdAccount {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Account info
  accountId  String  @unique // Meta Ad Account ID (act_xxxxx)
  businessId String? // Business Manager ID
  name       String
  currency   String  @default("GBP")
  timezone   String  @default("Europe/London")

  // Authentication
  accessToken    String // Encrypted access token
  tokenExpiresAt DateTime?
  refreshToken   String?

  // Pixel connection
  pixelId   String? // Connected Meta Pixel ID
  pixelName String?

  // Status
  isActive   Boolean   @default(true)
  lastSyncAt DateTime?

  // Relations
  campaigns AdCampaign[]
  audiences AdAudience[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Google Ads API credentials — stored once by an admin and shared across all
// OAuth flows. Only one row exists (singleton, keyed by key="default").
// Storing secrets in DB matches the MetaAdAccount pattern already in use here.
model GoogleAdsApiConfig {
  id  String @id @default(auto()) @map("_id") @db.ObjectId
  key String @unique @default("default")

  developerToken    String // Google Ads Developer Token (from API Centre)
  oauthClientId     String // Google Cloud Console → OAuth 2.0 Client → Client ID
  oauthClientSecret String // Google Cloud Console → OAuth 2.0 Client → Secret
  loginCustomerId   String // MCC / Manager account ID (10 digits, no dashes)
  redirectUri       String // e.g. https://locksafe.uk/api/admin/google-ads/oauth/callback

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Google Ads account connection (Phase 1 — read-only; tokens stored unencrypted
// matching MetaAdAccount convention. TODO(security): apply at-rest encryption
// across both before Phase 3 autonomy ships.)
model GoogleAdsAccount {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Customer ID without dashes, e.g. "1234567890" — NOT the AW-* tag ID
  customerId      String  @unique
  // Manager / MCC ID under which this customer sits (login-customer-id header)
  loginCustomerId String?
  name            String
  currency        String  @default("GBP")
  timezone        String  @default("Europe/London")

  // OAuth credentials (long-lived refresh token; access token is short-lived
  // and refreshed on demand by GoogleAdsClient)
  refreshToken   String
  accessToken    String?
  tokenExpiresAt DateTime?
  scope          String?

  // Status
  isActive   Boolean   @default(true)
  lastSyncAt DateTime?

  // Relations
  drafts GoogleAdsCampaignDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Phase 2 — AI-generated Google Ads campaign drafts.
// Stored separately from AdCampaign (Meta-only) to keep platforms isolated and
// avoid breaking the 30+ existing accessors of AdCampaign.account.pixelId etc.
// Drafts move through DRAFT → PENDING_APPROVAL → APPROVED → PUBLISHED.
model GoogleAdsCampaignDraft {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  accountId String           @db.ObjectId
  account   GoogleAdsAccount @relation(fields: [accountId], references: [id])

  // Lifecycle
  status String @default("DRAFT")
  // DRAFT | PENDING_APPROVAL | APPROVED | REJECTED | PUBLISHING | PUBLISHED | PAUSED | FAILED

  // Post-publish IDs (resource names from Google Ads API)
  googleCampaignId String? // numeric ID — uniqueness enforced only at publish time
  googleAdGroupId  String?
  googleAdId       String?
  googleBudgetId   String?

  // Campaign settings
  name            String
  dailyBudget     Float // GBP
  biddingStrategy String @default("MAXIMIZE_CONVERSIONS")
  targetCpa       Float?
  channel         String @default("SEARCH")

  // Targeting
  geoTargets      String[] @default(["2826"]) // Google geo target constants; 2826 = United Kingdom
  languageTargets String[] @default(["1000"]) // 1000 = English

  // Responsive Search Ad creative
  headlines       String[]
  descriptions    String[]
  finalUrl        String
  pinnedHeadlines Json? // optional pin map { headlineIndex: position }

  // Keywords
  keywords         Json // [{ text, matchType: "EXACT"|"PHRASE"|"BROAD" }]
  negativeKeywords String[] @default([])

  // AI metadata
  aiGenerated Boolean @default(true)
  aiPrompt    String?
  aiReasoning String?
  agentId     String? @db.ObjectId

  // Approval tracking
  approvalId     String?   @db.ObjectId
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?

  // Performance (synced)
  totalSpend       Float @default(0)
  totalConversions Int   @default(0)
  totalRevenue     Float @default(0)
  totalClicks      Int   @default(0)
  totalImpressions Int   @default(0)

  publishError String?
  publishedAt  DateTime?
  pausedAt     DateTime?
  adminNotes   String?

  // ── Post-publish verification (added 2026-06-04) ─────────────────────────
  // After publish, a cron compares the live Google campaign against playbook
  // structural floors (≥10 keywords per ad group, ≥1 RSA per ad group).
  // Catches the 2026-06-02 failure mode where campaigns published as
  // SERVING/ENABLED but had ad groups with zero keywords. See
  // google-ads-campaign-playbook.md §12.
  //
  // verificationStatus: "ok" | "structural_failure" | "drift_warning" | "google_pending" | "api_error"
  // verificationDetails: full VerificationResult blob for audit
  lastVerifiedAt      DateTime?
  verificationStatus  String?
  verificationDetails Json?

  // Forensic-validation geo-drift audit entries (added 2026-06-04, playbook §15).
  geoAuditEntries     GoogleAdsGeoAuditEntry[]

  // Manual-vs-AI provenance + post-publish snapshot.
  // createdBy: "ai" (default existing rows) | "admin" (manual via UI)
  // publishedSnapshot: full live state pulled back via GAQL after a successful
  //   publish. Used as the source of truth for cloning / future automations.
  createdBy         String? @default("ai") // "ai" | "admin"
  createdByAdminId  String? @db.ObjectId
  publishedSnapshot Json?
  snapshotAt        DateTime?
  templateId        String?  @db.ObjectId

  // ── Phase 2 campaign settings ─────────────────────────────────────────────
  // Location targeting precision
  geoExclusions     String[] @default([])
  // PRESENCE = only people physically in the target area (recommended)
  // PRESENCE_OR_INTEREST = also people searching about the area from anywhere
  locationMatchType String   @default("PRESENCE")

  // Bid adjustments (applied at publish time)
  // deviceBidAdjustments: { mobile: 25, tablet: 0, desktop: 0 } — percentage modifiers
  deviceBidAdjustments  Json?
  // adScheduleAdjustments: [{ dayOfWeek: "MONDAY", hourStart: 18, hourEnd: 23, bidModifier: 20 }]
  adScheduleAdjustments Json?

  // Ad group structure — if set, creates multiple ad groups instead of one flat group
  // [{ name: "Locked Out", keywords: [{text, matchType}], headlines: string[], descriptions: string[] }]
  adGroups Json?

  // Ad assets (callouts, sitelinks, call extension, structured snippets, price)
  // [{ type: "CALLOUT"|"SITELINK"|"CALL"|"STRUCTURED_SNIPPET"|"PRICE", ...data }]
  assets Json?

  // Shared negative keyword list (applied in addition to campaign-level negatives)
  sharedNegativeListId String? @db.ObjectId

  // Extended bidding
  targetRoas Float?

  // Flight dates (optional)
  startDate DateTime?
  endDate   DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSyncAt DateTime?

  suggestions CampaignSuggestion[]

  @@index([accountId])
  @@index([status])
}

// =========================================================================
// Google Ads Shared Negative Keyword List
// One list → applied to multiple campaigns. Edit once, updates everywhere.
// =========================================================================

// Forensic-validation geo-drift audit trail (added 2026-06-04).
// One entry per drift detection AND per admin remediation action. Lets us
// answer: what changed, when, was it accepted/reverted, and by whom.
// Source-of-truth model: publishedSnapshot.geoTargets is the immutable
// baseline. It is only mutated by the explicit `accept_as_new_baseline`
// action (recorded here). The cron's drift detection never silently
// rewrites the baseline. See google-ads-publish-verifier.ts + playbook §15.
model GoogleAdsGeoAuditEntry {
  id      String                 @id @default(auto()) @map("_id") @db.ObjectId
  draftId String                 @db.ObjectId
  draft   GoogleAdsCampaignDraft @relation(fields: [draftId], references: [id])

  // What kind of entry this is.
  // - "drift_detected"           : cron found live != baseline
  // - "reverted_to_baseline"     : admin pushed publishedSnapshot back to Google
  // - "accepted_as_new_baseline" : admin updated publishedSnapshot to current live
  action     String
  detectedAt DateTime
  actedAt    DateTime? // when an admin took action (revert/accept); null for pure detection
  actedBy    String? // admin ID or "cron"

  // The geo target ID arrays at the moment of detection / action.
  baselineSnapshot   String[] @default([]) // publishedSnapshot.geoTargets at the time
  liveGeoTargets     String[] @default([]) // Google live state at the time
  geoTargetsAdded    String[] @default([]) // in live, not in baseline
  geoTargetsRemoved  String[] @default([]) // in baseline, not in live
  notes              String?

  createdAt DateTime @default(now())

  @@index([draftId, detectedAt])
  @@index([action, detectedAt])
}

model GoogleAdsSharedNegativeList {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  keywords     String[] // negative keywords in this list
  googleListId String?  // resource ID once created in Google Ads

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================================================================
// Google Ads Automation Rules
// Evaluate every 4 hours via cron. Condition → Action mappings.
// =========================================================================
model GoogleAdsAutomationRule {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  enabled    Boolean  @default(true)
  condition  String   // SPEND_NO_CONV | CTR_DROP | BUDGET_80PCT
  thresholdSpend      Float?
  thresholdPeriodDays Int?
  thresholdCtr        Float?
  action     String   // PAUSE_CAMPAIGN | ALERT_TELEGRAM
  campaignIds String[] // ["*"] = all
  lastTriggeredAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// =========================================================================
// Google Ads Opportunity Scout
// =========================================================================
// One row per (geoTargetId, computedAt) cell, produced weekly by the
// Opportunity Scout subagent. Sourced from Google Ads KeywordPlanIdeaService
// per UK city/borough where we have eligible locksmiths (or zero, for the
// `kind = "RECRUIT"` variant which feeds the "where should we recruit"
// report).
model GoogleAdsOpportunity {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // "COVERAGE" — geos with ≥1 onboarded locksmith ready to fulfil leads.
  // "RECRUIT"  — geos with zero locksmiths; high score = sales recruit target.
  kind String @default("COVERAGE")

  // Google Ads GeoTargetConstant numeric ID + human label.
  geoTargetId String
  geoLabel    String

  // Scoring snapshot.
  computedAt             DateTime @default(now())
  score                  Float
  medianCpcGbp           Float
  medianCompetitionIndex Float
  competitionTier        String   @default("UNKNOWN") // LOW | MEDIUM | HIGH | UNKNOWN
  totalMonthlySearches   Int      @default(0)
  topKeywords            Json     // OpportunityKeyword[]

  // Fulfilment context (zero for RECRUIT rows).
  locksmithCount    Int      @default(0)
  locksmithIds      String[] @default([])
  supplyRatio       Float    @default(0)

  // Workflow.
  status      String   @default("NEW") // NEW | REVIEWED | DRAFTED | DISMISSED
  draftId     String?  @db.ObjectId
  dismissedAt DateTime?
  dismissedBy String?
  agentNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, status])
  @@index([geoTargetId, computedAt])
  @@index([score])
}

// Reusable Google Ads campaign template captured from a published draft.
// One row per "playbook" the admin wants to clone in future automations
// (manual-publish-now → save-as-template → AI agent reuses the geometry).
model GoogleAdsCampaignTemplate {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String  @unique
  description String?

  // Source provenance
  sourceDraftId          String? @db.ObjectId
  sourceGoogleCampaignId String?
  sourceAccountId        String? @db.ObjectId

