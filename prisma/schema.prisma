  agentId     String @db.ObjectId
  executionId String @db.ObjectId

  actionType    String // What action needs approval
  actionDetails String // JSON description
  reason        String // Why approval is needed

  // Optional structured target reference for fast lookup by approval consumers
  // (e.g. ad publish gate). actionDetails JSON remains the canonical source.
  targetType String? // e.g. "google_ads_draft", "ad_campaign"
  targetId   String? // FK string to the target row

  status String @default("pending") // pending, approved, rejected

  // Resolution
  resolvedBy String? // Admin ID
  resolvedAt DateTime?
