  headlines       String[] @default([])
  descriptions    String[] @default([])
  finalUrl        String
  keywords        Json
  negativeKeywords String[] @default([])

  // Full live snapshot of the published campaign at template-save time
  snapshot Json?

  tags     String[] @default([])
