#!/usr/bin/env bash
#
# Pre-push gate — catches the failure classes that have shipped broken Vercel
# builds, BEFORE the push leaves this machine:
#
#   1. Invalid Prisma schema                      (broke build 2026-06-06)
#   2. Type errors                                (broke build 2026-06-07)
#   3. Pushing while companion fixes sit
#      UNCOMMITTED under src/ or prisma/          (root cause of #2: schema was
#      pushed, its consumer fixes stayed local — local checks passed against the
#      working tree while the pushed commit was broken)
#
# Escape hatches (use deliberately):
#   SKIP_TSC=1 git push          — skip the typecheck (emergency only)
#   ALLOW_DIRTY_PUSH=1 git push  — push despite uncommitted src/prisma changes
#
# Enable once per clone:  git config core.hooksPath scripts/git-hooks
#
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
cd "$ROOT_DIR"

echo "[pre-push] 1/3 Validating Prisma schema..."
if ! npx prisma validate; then
  echo "[pre-push] ❌ Prisma schema is invalid — push aborted. Fix prisma/schema.prisma and retry." >&2
  exit 1
fi

if [ "${SKIP_TSC:-0}" != "1" ]; then
  echo "[pre-push] 2/3 Typechecking (~30-60s; SKIP_TSC=1 git push to skip)..."
  if ! npx tsc --noEmit; then
    echo "[pre-push] ❌ Type errors — push aborted. Fix them (or SKIP_TSC=1 for a genuine emergency)." >&2
    exit 1
  fi
else
  echo "[pre-push] 2/3 Typecheck SKIPPED (SKIP_TSC=1)"
fi

echo "[pre-push] 3/3 Checking the tree matches what you're pushing..."
if [ "${ALLOW_DIRTY_PUSH:-0}" != "1" ] && ! git diff --quiet -- src prisma; then
  echo "[pre-push] ❌ You have UNCOMMITTED changes under src/ or prisma/." >&2
  echo "            The checks above validated your WORKING TREE — but the commit you're" >&2
  echo "            pushing doesn't include those changes, so it may still be broken." >&2
  echo "            (This exact gap shipped a broken build on 2026-06-07.)" >&2
  echo "            → Commit or stash them first, or override: ALLOW_DIRTY_PUSH=1 git push" >&2
  git diff --stat -- src prisma | tail -8 >&2
  exit 1
fi

echo "[pre-push] ✅ All checks passed — pushing."
