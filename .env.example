# Environment variables for LockSafe UK
# =====================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =====================================
# CRON JOB AUTHENTICATION
# =====================================
# Secret key for authenticating cron job requests
# Used by: /api/cron/generate-payouts, /api/cron/sync-meta-performance
# Generate a secure random string: openssl rand -hex 32
CRON_SECRET="your-secure-random-string-here"

# =====================================
# DATABASE
# =====================================
# MongoDB connection string
# See: https://pris.ly/d/connection-strings
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/locksafe?retryWrites=true&w=majority"

# =====================================
# STRIPE CONFIGURATION
# =====================================
# Get your API keys from: https://dashboard.stripe.com/apikeys
# Use test keys for development (sk_test_..., pk_test_...)
# Use live keys for production (sk_live_..., pk_live_...)

# Secret key (server-side only - NEVER expose this)
STRIPE_SECRET_KEY="sk_test_..."

# Publishable key (can be exposed to client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook Signing Secret (for verifying webhook payloads)
# Get from: https://dashboard.stripe.com/webhooks
# For local testing with Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Connect Webhook Secret (for connected account events)
STRIPE_CONNECT_WEBHOOK_SECRET="whsec_..."

# Platform fee percentage (15% = 0.15)
STRIPE_PLATFORM_FEE_PERCENT="0.15"

# =====================================
# EMAIL CONFIGURATION (Resend)
# =====================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_..."

# Email sender address (must be verified in Resend)
EMAIL_FROM="noreply@yourdomain.com"

# =====================================
# MAPBOX CONFIGURATION
# =====================================
# Get your access token from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1..."

# =====================================
# APPLICATION URLs
# =====================================
# Base URL for the application (used for redirects, webhooks, emails)
NEXT_PUBLIC_BASE_URL="https://yourdomain.com"

# Stripe Connect redirect URLs
STRIPE_CONNECT_RETURN_URL="${NEXT_PUBLIC_BASE_URL}/locksmith/earnings?stripe=success"
STRIPE_CONNECT_REFRESH_URL="${NEXT_PUBLIC_BASE_URL}/locksmith/earnings?stripe=refresh"

# =====================================
# ADMIN CONFIGURATION
# =====================================
# Default admin credentials (change these in production!)
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="your-secure-password"

# JWT secret for admin authentication
# CRITICAL: Generate a strong secret for production!
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-jwt-secret-change-in-production"

# =====================================
# SITE CONFIGURATION
# =====================================
# The domain for the site (without trailing slash)
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# =====================================
# OPENAI (AI Ad Copy Generation)
# =====================================
# OpenAI API Key for AI-powered ad copy generation
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# =====================================
# META (FACEBOOK/INSTAGRAM) ADS - PIXEL TRACKING
# =====================================
# Meta Pixel ID (for browser-side tracking)
# Get it from: https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=""

# Meta Conversions API Access Token (for server-side tracking)
# Get it from: Events Manager -> Settings -> Generate Access Token
META_CONVERSIONS_API_TOKEN=""

# Meta Test Event Code (optional - for testing)
META_PIXEL_TEST_CODE=""

# =====================================
# META MARKETING API (Ad Creation & Management)
# =====================================
# For creating and managing Facebook/Instagram ads programmatically
# See: https://developers.facebook.com/docs/marketing-api/overview

# Meta App credentials (create app at: https://developers.facebook.com/apps)
META_APP_ID=""
META_APP_SECRET=""

# Long-lived Access Token for Marketing API
# Generate at: https://developers.facebook.com/tools/explorer/
# Required permissions: ads_management, ads_read, pages_read_engagement
META_ACCESS_TOKEN=""

# Ad Account ID (format: act_XXXXXXXXX)
# Find at: https://business.facebook.com/settings/ad-accounts
META_AD_ACCOUNT_ID=""

# Business Manager ID (optional)
META_BUSINESS_ID=""

# Facebook Page ID (for ad creatives AND organic posting)
META_PAGE_ID=""

# =====================================
# FACEBOOK GRAPH API (Organic Social Media Posting)
# =====================================
# These credentials are used for publishing organic posts to Facebook/Instagram
#
# SETUP GUIDE:
# 1. Go to https://developers.facebook.com/tools/explorer/
# 2. Select your app and generate token with permissions:
#    - pages_manage_posts
#    - pages_read_engagement
#    - instagram_basic (for Instagram)
#    - instagram_content_publish (for Instagram)
# 3. Get your Page Access Token (long-lived, never expires):
#    https://graph.facebook.com/v18.0/me/accounts?access_token={USER_TOKEN}
# 4. Copy Page ID and Page Access Token from the response
# 5. Add to Vercel environment variables OR use UI at /admin/organic/settings
#
# Note: META_PAGE_ID and META_ACCESS_TOKEN (above) are used for organic posting
# The system will create a SocialAccount record from these values
# Or you can add accounts directly via the UI at /admin/organic/settings

# =====================================
# GOOGLE ANALYTICS
# =====================================
# Google Analytics Measurement ID (starts with G-)
# Get it from: https://analytics.google.com/ -> Admin -> Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# =====================================
# GOOGLE SEARCH CONSOLE
# =====================================
# Google Search Console verification code
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# =====================================
# GOOGLE ADS
# =====================================
# Google Ads Customer ID (format: AW-XXXXXXXXX)
# Get it from: https://ads.google.com -> Tools & Settings -> Conversions
NEXT_PUBLIC_GOOGLE_ADS_ID=""

# Google Ads Conversion Labels
NEXT_PUBLIC_GOOGLE_LEAD_CONVERSION_LABEL=""
NEXT_PUBLIC_GOOGLE_PURCHASE_CONVERSION_LABEL=""

# =====================================
# MICROSOFT/BING ADS
# =====================================
# Microsoft UET Tag ID
# Get it from: https://ads.microsoft.com -> Tools -> UET tags
NEXT_PUBLIC_BING_UET_TAG_ID=""

# =====================================
# TIKTOK ADS (Future)
# =====================================
# TikTok Pixel ID
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""

# =====================================
# TELEGRAM NOTIFICATIONS (BOTFATHER)
# =====================================
# Telegram Bot Token - Get from @BotFather on Telegram
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the API token provided
TELEGRAM_BOT_TOKEN=""

# Telegram Chat ID - Where notifications will be sent
# Can be a group chat ID (negative number) or user ID (positive)
# To get your chat ID:
# 1. Add your bot to a group or start a chat with it
# 2. Send a message to the bot/group
# 3. Visit: https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# 4. Find the "chat" -> "id" field in the response
TELEGRAM_CHAT_ID=""

# Enable/Disable Telegram notifications (set to "true" to enable)
TELEGRAM_NOTIFICATIONS_ENABLED="true"

# Additional admin chat IDs for Telegram bot commands (comma-separated)
# Users with these IDs can use admin bot commands (/jobs, /stats, etc.)
TELEGRAM_ADMIN_CHAT_IDS=""

# =====================================
# AI AGENT INTEGRATION (OpenClaw)
# =====================================
# API key for authenticating agent requests to /api/agent/* endpoints
# Generate a secure random string: openssl rand -hex 32
AGENT_API_KEY="447bb87716422c610fd805b8b7b10f80e541e89854261c87351e1f6f124383b9"

# OpenClaw endpoint (optional - defaults to OpenAI API)
# Set this if running self-hosted OpenClaw
OPENCLAW_ENDPOINT=""

# OpenClaw model (optional - defaults to gpt-4-turbo-preview)
OPENCLAW_MODEL="gpt-4-turbo-preview"

# =====================================
# WHATSAPP BUSINESS API
# =====================================
# Meta WhatsApp Business API credentials
# See: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started

# WhatsApp Business Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=""

# WhatsApp Business Access Token (same as META_ACCESS_TOKEN or separate)
WHATSAPP_ACCESS_TOKEN=""

# Webhook verification token (set to same value in Meta App Dashboard)
# Generate a secure random string: openssl rand -hex 16
WHATSAPP_VERIFY_TOKEN="96979c40bd5bf88c09f3861d696b5829"

# WhatsApp Business Account ID
WHATSAPP_BUSINESS_ACCOUNT_ID=""

# =====================================
# PUSH NOTIFICATIONS - VAPID (Web Push)
# =====================================
# VAPID keys for web push notifications
# Generate using: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# =====================================
# BLAND.AI VOICE INTEGRATION
# =====================================
# Bland.ai API Key for authentication
# Get it from: https://app.bland.ai/dashboard/api-keys
BLAND_API_KEY=""

# Bland.ai Pathway ID (after uploading pathway)
BLAND_PATHWAY_ID=""

# Bland.ai Webhook Secret for authenticating incoming requests
# Generate a secure random string: openssl rand -hex 32
# Configure this same secret in Bland.ai pathway tool headers:
# Header Name: X-Bland-Webhook-Secret
# Header Value: <your-secret-here>
BLAND_WEBHOOK_SECRET=""

# =====================================
# TWILIO (REQUIRED for UK Phone Numbers)
# =====================================
# Bland.ai only provides US numbers natively.
# For UK, you MUST use Twilio and connect via BYOT (Bring Your Own Twilio)
#
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# UK Phone Number purchased from Twilio (for Bland.ai voice)
# This will be imported into Bland.ai for inbound calls
TWILIO_PHONE_NUMBER="+44..."

# Separate SMS Phone Number (optional - defaults to TWILIO_PHONE_NUMBER)
# Use this if you have a separate number for SMS notifications
TWILIO_SMS_PHONE_NUMBER=""

# Bland.ai Encrypted Key for BYOT
# Generated when you connect Twilio to Bland.ai
# IMPORTANT: This is only shown ONCE when created - save it!
# Generate at: https://app.bland.ai/dashboard/add-ons (BYOT section)
BLAND_ENCRYPTED_KEY=""

# =====================================
# SENTRY ERROR TRACKING (Optional but Recommended)
# =====================================
# Sentry DSN for error tracking and performance monitoring
# 1. Create account at https://sentry.io
# 2. Create a new Next.js project
# 3. Copy the DSN from Project Settings -> Client Keys (DSN)
# Only active in production (NODE_ENV=production)
NEXT_PUBLIC_SENTRY_DSN=""

# =====================================
# ONESIGNAL PUSH NOTIFICATIONS (Optional)
# =====================================
# OneSignal for native push notifications
# 1. Create account at https://onesignal.com
# 2. Create a new app (Web Push)
# 3. Copy App ID from Settings -> Keys & IDs
# 4. Copy REST API Key from Settings -> Keys & IDs
NEXT_PUBLIC_ONESIGNAL_APP_ID=""
ONESIGNAL_REST_API_KEY=""

# =====================================
# VERCEL BLOB STORAGE
# =====================================
# For file uploads (locksmith photos, job images, etc.)
# Get from: Vercel Dashboard -> Storage -> Blob -> Token
BLOB_READ_WRITE_TOKEN=""

# =====================================
# RETELL AI VOICE RECEPTIONIST
# =====================================
# Retell AI for automated phone receptionist (Sarah)
# 1. Create account at https://www.retellai.com
# 2. Create an agent and copy the Agent ID
# 3. Copy API Key from Settings -> API Keys
# 4. Set up webhook URL: https://yourdomain.com/api/retell/webhook
RETELL_API_KEY=""
RETELL_AGENT_ID=""
RETELL_PHONE_NUMBER=""

# =====================================
# AI AGENTS SYSTEM
# =====================================
# Enable/disable the autonomous agent system (CEO, CMO, COO, CTO agents)
AGENTS_ENABLED="false"

# =====================================
# VERCEL DEPLOYMENT
# =====================================
# Force clean build on Vercel (set to "1" to bypass cache)
VERCEL_FORCE_NO_BUILD_CACHE="1"

# =====================================
# DEVELOPMENT ONLY
# =====================================
# Set to "true" to enable test mode features
# TEST_MODE="true"

# =====================================
# POSTCODE / ADDRESS LOOKUP
# =====================================
# getAddress.io API key for real UK PAF-quality address lookup.
# Server-side only — the proxy at /api/postcode/lookup keeps this secret.
# If unset, the form falls back to manual address entry (and uses postcodes.io
# only for lat/lng so geo features keep working in local dev).
# Get a key at https://getaddress.io
GETADDRESS_API_KEY="T9jUKIKoM0a7DaZkofjt6Q51684"

# =====================================
# GOOGLE PLACES (postcode → address)
# =====================================
# Used by /api/postcode/lookup as the primary address provider.
# Requires "Places API (New)" enabled in Google Cloud Console with billing
# (Maps Platform gives $200/mo free credit — covers ~11k Autocomplete calls).
# Restrict the key to "Places API (New)" only. Server-side only — never exposed
# to the browser.
GOOGLE_PLACES_API_KEY="AIzaSyARvp9TtB-uPhhJdksPcijhrd0y38wZXAw"
