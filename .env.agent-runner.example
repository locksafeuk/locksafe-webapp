# ─────────────────────────────────────────────────────────────────────────────
# LockSafe Mac Studio Agent Runner — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file:   cp .env.agent-runner.example .env.agent-runner
# Fill in values — then start the runner: ./scripts/start-agents.sh
#
# ⚠️  NEVER commit .env.agent-runner to git (it's already in .gitignore below).
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (same as your Vercel DATABASE_URL)
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/locksafe?retryWrites=true&w=majority"

# JWT secret — must match the one used by your Vercel deployment
JWT_SECRET="your-jwt-secret-same-as-vercel"

# Telegram bot token + chat ID for admin alerts
# The runner sends a message on start, stop, and consecutive errors.
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# ── AGENT SYSTEM ─────────────────────────────────────────────────────────────

# Must be "true" — this is the whole point of the runner
AGENTS_ENABLED=true

# ── OLLAMA (LOCAL — the reason we're running on Mac Studio) ──────────────────

# Force Ollama on — never fall through to OpenAI for agent calls
OLLAMA_RUNTIME_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434

# Models to use — match what you have pulled on this Mac
# Run `ollama list` to see available models
OLLAMA_MODEL_AGENT=qwen3:30b-a3b
OLLAMA_MODEL_CONTENT=qwen3:32b
OLLAMA_MODEL_FAST=qwen2.5:3b
OLLAMA_MODEL_QUALITY=qwen3:32b
OLLAMA_MODEL_REASONING=qwen3:32b
OLLAMA_TIMEOUT_MS=120000

# Strict mode — fail loudly if Ollama is down instead of silently using OpenAI
OLLAMA_STRICT=true
OLLAMA_AGENT_STRICT=true

# Disable OpenAI fallback completely on the agent runner
# (OpenAI is still available on Vercel for web requests)
ENABLE_OPENAI_FALLBACK=false

# ── OPENAI (fallback disabled above, but key needed to avoid import errors) ──
OPENAI_API_KEY=sk-disabled

# ── APP ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://locksafe.uk
NEXT_PUBLIC_SITE_URL=https://locksafe.uk

# ── CRON AUTH ─────────────────────────────────────────────────────────────────
# Same secret used by Vercel crons — needed if any agent triggers cron endpoints internally
CRON_SECRET="your-cron-secret-same-as-vercel"

# ── EXTERNAL INTEGRATIONS (copy from Vercel env) ─────────────────────────────

# Resend (email)
RESEND_API_KEY=re_...

# Stripe (for payout agent actions)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Ads (CMO / Ads Specialist agent)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Meta (CMO agent)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Mapbox (if any agent uses routing/geo)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# Serper.dev (scraper / CMO research)
SERPER_API_KEY=

# Vercel Blob (for photo/file storage by agents)
BLOB_READ_WRITE_TOKEN=

# ── OPTIONAL: AGENT CONCURRENCY ──────────────────────────────────────────────
# How many agents can run heartbeats simultaneously (default: 3)
# Increase on Mac Ultra since you have 24 cores — try 5
AGENT_HEARTBEAT_CONCURRENCY=5
