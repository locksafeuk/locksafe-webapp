{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "regions": ["lhr1"],
  "crons": [
    {
      "path": "/api/cron/onboarding-nudge",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/google-ads-opportunity-scout",
      "schedule": "0 4 * * 1"
    },
    {
      "path": "/api/cron/agent-reflection",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/agents/heartbeat",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/google-ads-suggestions",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/memory-consolidate",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/cron/auto-draft-existing-locksmiths",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/generate-organic",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/publish-organic",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/sync-organic-performance",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/availability-schedule",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/generate-district-landings",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/google-ads-auto-pause",
      "schedule": "15 6 * * *"
    },
    {
      "path": "/api/cron/google-ads-drift-sync",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/lead-outreach-sequence",
      "schedule": "0 8 * * 1-5"
    },
    {
      "path": "/api/cron/photo-upload-reminder",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/insurance-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/dbs-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/email-campaigns",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/scraper",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/enrich-leads",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/google-ads-automation-rules",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/verify-published-drafts",
      "schedule": "*/10 * * * *"
    }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 300
    }
  }
}
