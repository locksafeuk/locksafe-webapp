{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "regions": ["lhr1"],
  "crons": [
    {
      "path": "/api/cron/google-ads-opportunity-scout",
      "schedule": "0 4 * * 1"
    },
    {
      "path": "/api/cron/agent-reflection",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/google-ads-suggestions",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/memory-consolidate",
      "schedule": "0 6 * * 0"
    }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 300
    }
  }
}
