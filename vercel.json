{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "regions": ["lhr1"],
  "crons": [
    {
      "path": "/api/cron/voice-call-watchdog",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/google-ads-fraud-monitor",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/google-ads-opportunity-scout",
      "schedule": "0 4 * * 1"
    }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 300
    }
  }
}
