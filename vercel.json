{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "regions": ["lhr1"],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/advance-auctions",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sla-monitor",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/dispatch-scheduled-jobs",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/sync-commission-tiers",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/auto-redispatch",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/review-requests",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/generate-invoices",
      "schedule": "0 6 2 * *"
    },
    {
      "path": "/api/cron/performance-scores",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/win-back",
      "schedule": "0 10 * * *"
    }
  ]
}
