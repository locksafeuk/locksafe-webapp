{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "regions": ["lhr1"],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/advance-auctions",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/sync-commission-tiers",
      "schedule": "0 2 * * *"
    }
  ]
}
